<controls:MicaWindow
    x:Name="RootWindow"
    x:Class="FluentFlyoutWPF.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
    xmlns:controls="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
    xmlns:viewModels="clr-namespace:FluentFlyoutWPF.ViewModels"
    Height="150"
    Width="380"
    Top="-9999"
    WindowStyle="None"
    ShowInTaskbar="False"
    ResizeMode="NoResize"
    ChangeTitleColorWhenInactive="False"
    TextOptions.TextRenderingMode="ClearType"
    TextOptions.TextFormattingMode="Ideal"
    FontFamily="{Binding Settings.FontFamily}"
    FlowDirection="{Binding Settings.FlowDirection}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    MouseEnter="MicaWindow_MouseEnter"
    Loaded="MicaWindow_Loaded"
    Icon="/Resources/FluentFlyout2.ico"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance viewModels:MainWindowViewModel}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Converters.xaml"/>
                <ResourceDictionary Source="/Resources/Styles/PlayerThemeResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <EventTrigger.Actions>
                <BeginStoryboard>
                    <Storyboard x:Name="WindowStoryboard">
                        <DoubleAnimation Storyboard.TargetProperty="(Window.Top)"
                                         Duration="0:0:0.3">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetProperty="(Window.Opacity)"
                                         Duration="0:0:0.3">
                            <DoubleAnimation.EasingFunction>
                                <CubicEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="WindowScale"
                                         Storyboard.TargetProperty="ScaleX"
                                         Duration="0:0:0.3"
                                         To="1.0">
                            <DoubleAnimation.EasingFunction>
                                <QuarticEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <DoubleAnimation Storyboard.TargetName="WindowScale"
                                         Storyboard.TargetProperty="ScaleY"
                                         Duration="0:0:0.3"
                                         To="1.0">
                            <DoubleAnimation.EasingFunction>
                                <QuarticEase EasingMode="EaseOut"/>
                            </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger.Actions>
        </EventTrigger>
    </Window.Triggers>

    <Grid RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="WindowScale"
                                ScaleX="0.95"
                                ScaleY="0.95"/>
            </TransformGroup>
        </Grid.RenderTransform>
        <ui:Button x:Name="MediaFlyoutCloseButton"
                   Width="28"
                   Height="28"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,8,8,0"
                   Appearance="Transparent"
                   Padding="0"
                   Command="{Binding CloseFlyoutCommand}"
                   Visibility="{Binding IsPrimaryCloseVisible, Converter={StaticResource BoolToVisibleCollapsedConverter}}">
            <ui:SymbolIcon Symbol="Dismiss20"
                           Filled="True"/>
        </ui:Button>

        <Grid>
            <Image x:Name="BackgroundImageBackground"
                   Stretch="UniformToFill"
                   Opacity="0"
                   IsHitTestVisible="False"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   RenderTransformOrigin="0.5,0.5"
                   ClipToBounds="True">
                <Image.Effect>
                    <BlurEffect Radius="0"/>
                </Image.Effect>
            </Image>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Name="MainStackPanel"
                            Grid.Row="0"
                            Margin="12"
                            Orientation="Horizontal">

                    <Border Name="SongImageBorder"
                            CornerRadius="6"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            Margin="0"
                            ClipToBounds="False"
                            Width="78"
                            Height="78">
                        <Border.Effect>
                            <DropShadowEffect x:Name="SongImageGlow"
                                              BlurRadius="15"
                                              ShadowDepth="0"
                                              Opacity="0"
                                              Color="#FFFFFFFF"/>
                        </Border.Effect>
                        <ui:SymbolIcon Name="SongImagePlaceholder"
                                       Symbol="MusicNote220"
                                       FontSize="40"
                                       Filled="True"
                                       Visibility="{Binding IsPlaceholderVisible, Converter={StaticResource BoolToVisibleCollapsedConverter}}"/>
                        <Border.Background>
                            <ImageBrush x:Name="SongImage"
                                        ImageSource="{Binding NowPlaying.CoverImage}"
                                        Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>

                    <Grid Name="BodyGrid"
                          VerticalAlignment="Center">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Name="SongInfoStackPanel"
                                    Grid.Row="0"
                                    Grid.Column="0"
                                    Margin="12,0,0,0"
                                    Orientation="Vertical"
                                    VerticalAlignment="Center"
                                    ToolTipService.InitialShowDelay="800"
                                    ToolTipService.Placement="Top"
                                    ToolTipService.VerticalOffset="-16">
                            <TextBlock Name="SongTitle"
                                       Text="{Binding NowPlaying.Title}"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Name="SongArtist"
                                       Text="{Binding NowPlaying.Artist}"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Opacity="0.5"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <StackPanel Name="ControlsStackPanel"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Height="35"
                                    Margin="12,8,0,0">

                            <ui:Button Name="ControlBack"
                                       Style="{StaticResource PlayerFlyoutTransportButtonStyle}"
                                       Margin="2,0,8,0"
                                       IsEnabled="{Binding NowPlaying.AreTransportControlsEnabled}"
                                       Opacity="{Binding NowPlaying.TransportOpacity}"
                                       Command="{Binding SkipPreviousCommand}">
                                <ui:SymbolIcon Name="SymbolBack"
                                               Symbol="Previous20"
                                               Filled="True"/>
                            </ui:Button>

                            <ui:Button Name="ControlPlayPause"
                                       Style="{StaticResource PlayerFlyoutPrimaryButtonStyle}"
                                       Margin="0,0,8,0"
                                       IsEnabled="{Binding NowPlaying.IsPlayPauseEnabled}"
                                       Opacity="{Binding NowPlaying.PlayPauseOpacity}"
                                       Command="{Binding PlayPauseCommand}">
                                <ui:SymbolIcon Name="SymbolPlayPause"
                                               Symbol="{Binding NowPlaying.PlayPauseCompactSymbol}"
                                               Filled="True"/>
                            </ui:Button>

                            <ui:Button Name="ControlForward"
                                       Style="{StaticResource PlayerFlyoutTransportButtonStyle}"
                                       Margin="0,0,8,0"
                                       IsEnabled="{Binding NowPlaying.AreTransportControlsEnabled}"
                                       Opacity="{Binding NowPlaying.TransportOpacity}"
                                       Command="{Binding SkipNextCommand}">
                                <ui:SymbolIcon Name="SymbolForward"
                                               Symbol="Next20"
                                               Filled="True"/>
                            </ui:Button>

                            <ui:Button Name="ControlClose"
                                       Style="{StaticResource PlayerFlyoutCloseButtonStyle}"
                                       Margin="0,0,8,0"
                                       Visibility="{Binding IsCompactCloseVisible, Converter={StaticResource BoolToVisibleCollapsedConverter}}"
                                       Command="{Binding CloseFlyoutCommand}">
                                <ui:SymbolIcon Symbol="Dismiss20"
                                               Filled="True"/>
                            </ui:Button>

                            <ui:Button Name="ControlRepeat"
                                       Style="{StaticResource PlayerFlyoutTransportButtonStyle}"
                                       Margin="0,0,8,0"
                                       Visibility="{Binding NowPlaying.RepeatVisibility}"
                                       Command="{Binding ToggleRepeatCommand}">
                                <ui:SymbolIcon Name="SymbolRepeat"
                                               Symbol="{Binding NowPlaying.RepeatSymbol}"
                                               Filled="false"
                                               Foreground="{Binding NowPlaying.RepeatForeground}"
                                               Opacity="{Binding NowPlaying.RepeatIconOpacity}"
                                               FontSize="18"/>
                            </ui:Button>

                            <ui:Button Name="ControlShuffle"
                                       Style="{StaticResource PlayerFlyoutTransportButtonStyle}"
                                       Margin="0,0,8,0"
                                       Visibility="{Binding NowPlaying.ShuffleVisibility}"
                                       Command="{Binding ToggleShuffleCommand}">
                                <ui:SymbolIcon Name="SymbolShuffle"
                                               Symbol="{Binding NowPlaying.ShuffleSymbol}"
                                               Filled="false"
                                               Foreground="{Binding NowPlaying.ShuffleForeground}"
                                               Opacity="{Binding NowPlaying.ShuffleIconOpacity}"
                                               FontSize="18"/>
                            </ui:Button>

                            <StackPanel Name="MediaIdStackPanel"
                                        Orientation="Horizontal"
                                        Width="72"
                                        Visibility="{Binding IsMediaIdVisible, Converter={StaticResource BoolToVisibleCollapsedConverter}}">
                                <Image x:Name="MediaIdIcon"
                                       Width="14"
                                       Height="14"
                                       Source="{Binding MediaIdIcon}"
                                       Visibility="{Binding MediaIdIcon, Converter={StaticResource NullToCollapsedConverter}}"/>
                                <TextBlock Name="MediaId"
                                           VerticalAlignment="Center"
                                           FontSize="10"
                                           Width="50"
                                           Margin="6,0,0,0"
                                           FontWeight="Regular"
                                           Opacity="0.25"
                                           Text="{Binding MediaIdText}"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <DockPanel Grid.Row="1"
                           x:Name="SeekbarWrapper"
                           HorizontalAlignment="Stretch"
                           Margin="16,0,16,12"
                           LastChildFill="True"
                           VerticalAlignment="Center"
                           Visibility="{Binding IsSeekbarVisible, Converter={StaticResource BoolToVisibleCollapsedConverter}}">
                    <TextBlock Name="SeekbarCurrentDuration"
                               Text="{Binding NowPlaying.CurrentTime}"
                               Opacity="0.6"
                               FontSize="11"
                               FontWeight="Medium"
                               DockPanel.Dock="Left"
                               Width="45"
                               Margin="0,0,4,0"
                               TextAlignment="Left"
                               VerticalAlignment="Center"
                               Height="18"/>
                    <TextBlock Name="SeekbarMaxDuration"
                               Text="{Binding NowPlaying.TotalTime}"
                               Opacity="0.6"
                               FontSize="11"
                               FontWeight="Medium"
                               DockPanel.Dock="Right"
                               Width="45"
                               Margin="4,0,0,0"
                               TextAlignment="Right"
                               VerticalAlignment="Center"
                               Height="18"/>
                    <Slider Name="Seekbar"
                            Value="{Binding NowPlaying.SeekValue}"
                            Maximum="{Binding NowPlaying.SeekMaximum}"
                            Minimum="0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center"
                            Cursor="Hand"
                            Height="18"
                            PreviewMouseLeftButtonDown="Seekbar_OnPreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="Seekbar_OnPreviewMouseLeftButtonUp"
                            ValueChanged="Seekbar_OnValueChanged"/>
                </DockPanel>
            </Grid>
        </Grid>

        <tray:NotifyIcon x:Name="nIcon"
                         LeftClick="nIcon_LeftClick"
                         FocusOnLeftClick="False"
                         MenuOnRightClick="True"
                         TooltipText="FluentFlyout"
                         Icon="/Resources/FluentFlyout2.ico"
                         Margin="0,127,0,114"
                         Visibility="Collapsed">
            <tray:NotifyIcon.Menu>
                <ContextMenu>
                    <ui:MenuItem x:Name="NotifyIconSettings"
                                 Header="{DynamicResource TrayIcon_SettingsOption}"
                                 Command="{Binding OpenSettingsCommand}">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Settings20"/>
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>

                    <Separator/>

                    <ui:MenuItem x:Name="NotifyIconRepository"
                                 Header="{DynamicResource TrayIcon_GitHubRepositoryOption}"
                                 Command="{Binding OpenRepositoryCommand}">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="DocumentChevronDouble20"/>
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                    <ui:MenuItem x:Name="NotifyIconViewLogs"
                                 Header="{DynamicResource TrayIcon_ViewLogsOption}"
                                 Command="{Binding OpenLogsFolderCommand}">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="FolderOpen20"/>
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                    <ui:MenuItem x:Name="NotifyIconReportBug"
                                 Header="{DynamicResource TrayIcon_ReportBugOption}"
                                 Command="{Binding ReportBugCommand}">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="Bug20"/>
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>

                    <Separator/>

                    <ui:MenuItem x:Name="NotifyIconQuit"
                                 Header="{DynamicResource TrayIcon_QuitOption}"
                                 Command="{Binding QuitApplicationCommand}">
                        <ui:MenuItem.Icon>
                            <ui:SymbolIcon Symbol="ArrowExit20"/>
                        </ui:MenuItem.Icon>
                    </ui:MenuItem>
                </ContextMenu>
            </tray:NotifyIcon.Menu>
        </tray:NotifyIcon>

    </Grid>
</controls:MicaWindow>


