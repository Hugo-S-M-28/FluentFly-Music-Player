<controls:MicaWindow x:Name="RootWindow" x:Class="FluentFlyoutWPF.MainWindow"
                     xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                     xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                     xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                     xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                     xmlns:tray="http://schemas.lepo.co/wpfui/2022/xaml/tray"
                     xmlns:controls="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
                     xmlns:viewModels="clr-namespace:FluentFlyoutWPF.ViewModels"
                     Height="150"
                     Width="380"
                     Top="-9999"
                     WindowStyle="None"
                     ShowInTaskbar="False"
                     ResizeMode="NoResize"
                     ChangeTitleColorWhenInactive="False"
                     TextOptions.TextRenderingMode="ClearType"
                     TextOptions.TextFormattingMode="Ideal"
                     FontFamily="{Binding FontFamily}"
                     FlowDirection="{Binding FlowDirection}"
                     MouseEnter="MicaWindow_MouseEnter"
                     Loaded="MicaWindow_Loaded"
                     Icon="/Resources/FluentFlyout2.ico"
                     mc:Ignorable="d"
                     d:DataContext="{d:DesignInstance viewModels:UserSettings}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Wpf.Ui;component/Resources/Theme/Dark.xaml" />
                <ResourceDictionary Source="pack://application:,,,/Wpf.Ui;component/Resources/Wpf.Ui.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Window.Triggers>
            <EventTrigger RoutedEvent="Window.Loaded">
                <EventTrigger.Actions>
                    <BeginStoryboard>
                        <Storyboard x:Name="WindowStoryboard">
                            <DoubleAnimation Storyboard.TargetProperty="(Window.Top)" Duration="0:0:0.3">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetProperty="(Window.Opacity)" Duration="0:0:0.3">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="WindowScale" Storyboard.TargetProperty="ScaleX" Duration="0:0:0.3" To="1.0">
                                <DoubleAnimation.EasingFunction>
                                    <QuarticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                            <DoubleAnimation Storyboard.TargetName="WindowScale" Storyboard.TargetProperty="ScaleY" Duration="0:0:0.3" To="1.0">
                                <DoubleAnimation.EasingFunction>
                                    <QuarticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger.Actions>
            </EventTrigger>
        </Window.Triggers>

        <Grid RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="WindowScale" ScaleX="0.95" ScaleY="0.95"/>
                </TransformGroup>
            </Grid.RenderTransform>
            <ui:Button x:Name="MediaFlyoutCloseButton"
                   Width="28"
                   Height="28"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Margin="0,8,8,0"
                   Appearance="Transparent"
                   Padding="0"
                   Click="MediaFlyoutCloseButton_Click"
                   Visibility="Collapsed">
                <ui:SymbolIcon Symbol="Dismiss20"
                           Filled="True"/>
            </ui:Button>

            <Grid>
                <Image x:Name="BackgroundImageStyle1"
                   Stretch="UniformToFill"
                   Opacity="1"
                   IsHitTestVisible="False"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderTransformOrigin="0.5,0.5"
                   Visibility="Collapsed"
                   ClipToBounds="True">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1.2"
                                        ScaleY="1.2"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                    <Image.Effect>
                        <BlurEffect Radius="50"/>
                    </Image.Effect>
                    <Image.OpacityMask>
                        <RadialGradientBrush GradientOrigin="0.2,0.5"
                                         Center="0.1,0.5"
                                         RadiusX="0.7"
                                         RadiusY="0.3">
                            <GradientStop Color="#FF000000"
                                      Offset="0.0"/>
                            <GradientStop Color="#00000080"
                                      Offset="0.75"/>
                            <GradientStop Color="#00000000"
                                      Offset="1.0"/>
                        </RadialGradientBrush>
                    </Image.OpacityMask>
                </Image>

                <Image x:Name="BackgroundImageStyle2"
                   Stretch="Fill"
                   Opacity="0.8"
                   IsHitTestVisible="False"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderTransformOrigin="0.5,0.5"
                   Visibility="Collapsed"
                   ClipToBounds="True">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1.8"
                                        ScaleY="1.8"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                    <Image.Effect>
                        <BlurEffect Radius="200"/>
                    </Image.Effect>
                    <Image.OpacityMask>
                        <RadialGradientBrush GradientOrigin="0.5,1"
                                         Center="0.5,1"
                                         RadiusX="0.4"
                                         RadiusY="0.7">
                            <GradientStop Color="#FF000000"
                                      Offset="0.0"/>
                            <GradientStop Color="#00000000"
                                      Offset="1.0"/>
                        </RadialGradientBrush>
                    </Image.OpacityMask>
                </Image>

                <Image x:Name="BackgroundImageStyle3"
                   Stretch="UniformToFill"
                   Opacity="0.3"
                   IsHitTestVisible="False"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderTransformOrigin="0.5,0.5"
                   Visibility="Collapsed">
                    <Image.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform ScaleX="1.2"
                                        ScaleY="1.2"/>
                        </TransformGroup>
                    </Image.RenderTransform>
                    <Image.Effect>
                        <BlurEffect Radius="50"/>
                    </Image.Effect>
                </Image>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Name="MainStackPanel"
                            Grid.Row="0"
                            Margin="12"
                            Orientation="Horizontal">

                        <Border Name="SongImageBorder"
                            CornerRadius="6"
                            BorderThickness="1"
                            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                            Margin="0"
                            ClipToBounds="False"
                            Width="78"
                            Height="78">
                            <Border.Effect>
                                <DropShadowEffect x:Name="SongImageGlow"
                                              BlurRadius="15"
                                              ShadowDepth="0"
                                              Opacity="0"
                                              Color="White"/>
                            </Border.Effect>
                            <ui:SymbolIcon Name="SongImagePlaceholder"
                                       Symbol="MusicNote220"
                                       FontSize="40"
                                       Filled="True"
                                       Visibility="Collapsed"/>
                            <Border.Background>
                                <ImageBrush x:Name="SongImage"
                                        ImageSource="{Binding NowPlaying.CoverImage, ElementName=RootWindow}"
                                        Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>

                        <Grid Name="BodyGrid"
                          VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Name="SongInfoStackPanel"
                                    Grid.Row="0" Grid.Column="0"
                                    Margin="12,0,0,0"
                                    Orientation="Vertical"
                                    VerticalAlignment="Center"
                                    ToolTipService.InitialShowDelay="800"
                                    ToolTipService.Placement="Top"
                                    ToolTipService.VerticalOffset="-16">
                                <TextBlock Name="SongTitle"
                                       Text="{Binding NowPlaying.Title, ElementName=RootWindow}"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       TextTrimming="CharacterEllipsis"/>
                                <TextBlock Name="SongArtist"
                                       Text="{Binding NowPlaying.Artist, ElementName=RootWindow}"
                                       FontSize="14"
                                       FontWeight="Medium"
                                       Opacity="0.5"
                                       TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <StackPanel Name="ControlsStackPanel"
                                    Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Height="35"
                                    Margin="12,8,0,0">

                                <ui:Button Name="ControlBack"
                                       Height="32"
                                       Width="32"
                                       Margin="2,0,8,0"
                                       VerticalAlignment="Center"
                                       Appearance="Transparent"
                                       Padding="0"
                                       Focusable="False"
                                       Click="Back_Click">
                                    <ui:SymbolIcon Name="SymbolBack"
                                               Symbol="Previous20"
                                               Filled="True"/>
                                </ui:Button>

                                <ui:Button Name="ControlPlayPause"
                                       Height="36"
                                       Width="36"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Appearance="Primary"
                                       Padding="0"
                                       Focusable="False"
                                       Click="PlayPause_Click">
                                    <ui:SymbolIcon Name="SymbolPlayPause"
                                               Symbol="Pause16"
                                               Filled="True"/>
                                </ui:Button>

                                <ui:Button Name="ControlForward"
                                       Height="32"
                                       Width="32"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Appearance="Transparent"
                                       Padding="0"
                                       Focusable="False"
                                       Click="Forward_Click">
                                    <ui:SymbolIcon Name="SymbolForward"
                                               Symbol="Next20"
                                               Filled="True"/>
                                </ui:Button>

                                <ui:Button Name="ControlClose"
                                       Width="28"
                                       Height="28"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Appearance="Transparent"
                                       Padding="0"
                                       Visibility="Collapsed"
                                       Click="MediaFlyoutCloseButton_Click">
                                    <ui:SymbolIcon Symbol="Dismiss20"
                                               Filled="True"/>
                                </ui:Button>

                                <ui:Button Name="ControlRepeat"
                                       Height="32"
                                       Width="32"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Appearance="Transparent"
                                       Padding="0"
                                       Focusable="False"
                                       Click="Repeat_Click">
                                    <ui:SymbolIcon Name="SymbolRepeat"
                                               Symbol="ArrowRepeatAllOff24"
                                               Filled="false"
                                               Opacity="0.5"
                                               FontSize="18"/>
                                </ui:Button>

                                <ui:Button Name="ControlShuffle"
                                       Height="32"
                                       Width="32"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"
                                       Appearance="Transparent"
                                       Padding="0"
                                       Focusable="False"
                                       Click="Shuffle_Click">
                                    <ui:SymbolIcon Name="SymbolShuffle"
                                               Symbol="ArrowShuffleOff24"
                                               Filled="false"
                                               Opacity="0.5"
                                               FontSize="18"/>
                                </ui:Button>

                                <StackPanel Name="MediaIdStackPanel"
                                        Orientation="Horizontal"
                                        Width="72">
                                    <Image x:Name="MediaIdIcon"
                                       Width="14"
                                       Height="14"/>
                                    <TextBlock Name="MediaId"
                                           VerticalAlignment="Center"
                                           FontSize="10"
                                           Width="50"
                                           Margin="6,0,0,0"
                                           FontWeight="Regular"
                                           Opacity="0.25"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <DockPanel Grid.Row="1"
                           x:Name="SeekbarWrapper"
                           HorizontalAlignment="Stretch"
                           Margin="16,0,16,12"
                           LastChildFill="True"
                           VerticalAlignment="Center">
                        <TextBlock Name="SeekbarCurrentDuration"
                               Text="{Binding NowPlaying.CurrentTime, ElementName=RootWindow}"
                               Opacity="0.5"
                               FontSize="12"
                               DockPanel.Dock="Left"
                               Width="45"
                               Margin="0,0,2,0"
                               TextAlignment="Left"
                               VerticalAlignment="Center"
                               Height="18"/>
                        <TextBlock Name="SeekbarMaxDuration"
                               Text="{Binding NowPlaying.TotalTime, ElementName=RootWindow}"
                               Opacity="0.5"
                               FontSize="12"
                               DockPanel.Dock="Right"
                               Width="45"
                               Margin="2,0,0,0"
                               TextAlignment="Right"
                               VerticalAlignment="Center"
                               Height="18"/>
                        <Slider Name="Seekbar"
                            Value="{Binding NowPlaying.SeekValue, ElementName=RootWindow}"
                            Maximum="{Binding NowPlaying.SeekMaximum, ElementName=RootWindow}"
                            Minimum="0"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Center"
                            VerticalContentAlignment="Center"
                            Height="18"
                            PreviewMouseLeftButtonDown="Seekbar_OnPreviewMouseLeftButtonDown"
                            PreviewMouseLeftButtonUp="Seekbar_OnPreviewMouseLeftButtonUp"
                            ValueChanged="Seekbar_OnValueChanged"/>
                    </DockPanel>
                </Grid>
            </Grid>

            <tray:NotifyIcon x:Name="nIcon"
                         LeftClick="nIcon_LeftClick"
                         FocusOnLeftClick="False"
                         MenuOnRightClick="True"
                         TooltipText="FluentFlyout"
                         Icon="/Resources/FluentFlyout2.ico"
                         Margin="0,127,0,114"
                         Visibility="Collapsed">
                <tray:NotifyIcon.Menu>
                    <ContextMenu>
                        <ui:MenuItem x:Name="NotifyIconSettings"
                                 Header="{DynamicResource TrayIcon_SettingsOption}"
                                 Click="openSettings">
                            <ui:MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Settings20"/>
                            </ui:MenuItem.Icon>
                        </ui:MenuItem>

                        <Separator/>

                        <ui:MenuItem x:Name="NotifyIconRepository"
                                 Header="{DynamicResource TrayIcon_GitHubRepositoryOption}"
                                 Click="openRepository">
                            <ui:MenuItem.Icon>
                                <ui:SymbolIcon Symbol="DocumentChevronDouble20"/>
                            </ui:MenuItem.Icon>
                        </ui:MenuItem>
                        <ui:MenuItem x:Name="NotifyIconViewLogs"
                                 Header="{DynamicResource TrayIcon_ViewLogsOption}"
                                 Click="openLogsFolder">
                            <ui:MenuItem.Icon>
                                <ui:SymbolIcon Symbol="FolderOpen20"/>
                            </ui:MenuItem.Icon>
                        </ui:MenuItem>
                        <ui:MenuItem x:Name="NotifyIconReportBug"
                                 Header="{DynamicResource TrayIcon_ReportBugOption}"
                                 Click="reportBug">
                            <ui:MenuItem.Icon>
                                <ui:SymbolIcon Symbol="Bug20"/>
                            </ui:MenuItem.Icon>
                        </ui:MenuItem>

                        <Separator/>

                        <ui:MenuItem x:Name="NotifyIconQuit"
                                 Header="{DynamicResource TrayIcon_QuitOption}"
                                 Click="NotifyIconQuit_Click">
                            <ui:MenuItem.Icon>
                                <ui:SymbolIcon Symbol="ArrowExit20"/>
                            </ui:MenuItem.Icon>
                        </ui:MenuItem>
                    </ContextMenu>
                </tray:NotifyIcon.Menu>
            </tray:NotifyIcon>

        </Grid>
    </controls:MicaWindow>


