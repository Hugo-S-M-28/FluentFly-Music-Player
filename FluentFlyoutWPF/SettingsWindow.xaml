<ui:FluentWindow
    x:Class="FluentFlyoutWPF.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:FluentFlyoutWPF"
    xmlns:pages="clr-namespace:FluentFlyoutWPF.Pages"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    mc:Ignorable="d"
    Height="750"
    MinHeight="500"
    MinWidth="800"
    Width="1000"
    WindowStartupLocation="CenterScreen"
    Title="{DynamicResource App_ProductName}"
    Icon="/Resources/FluentFlyout2.ico"
    TextOptions.TextRenderingMode="ClearType"
    TextOptions.TextFormattingMode="Ideal"
    FontFamily="{Binding Settings.FontFamily}"
    FlowDirection="{Binding Settings.FlowDirection}"
    Closing="SettingsWindow_Closing"
    xmlns:viewModels="clr-namespace:FluentFlyoutWPF.ViewModels"
    d:DataContext="{d:DesignInstance viewModels:SettingsShellViewModel}"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    Loaded="SettingsWindow_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <ui:NavigationView x:Name="RootNavigation"
                           Grid.Row="1"
                           PaneDisplayMode="Left"
                           TransitionDuration="300"
                           Navigated="RootNavigation_OnNavigated"
                           IsPaneToggleVisible="true"
                           Margin="0"
                           FrameMargin="0, 0, 0, 0"
                           OpenPaneLength="250"
                           IsTopSeparatorVisible="false"
                           IsFooterSeparatorVisible="false">
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="{DynamicResource Lib_Title}"
                                       Icon="{ui:SymbolIcon Library24}"
                                       TargetPageType="{x:Type pages:LibraryPage}"
                                       Visibility="{Binding Settings.InternalPlayerEnabled, Converter={StaticResource BoolToVisibleCollapsedConverter}}"/>
                <ui:NavigationViewItem Content="{DynamicResource HomeTitle}"
                                       Icon="{ui:SymbolIcon Home24}"
                                       TargetPageType="{x:Type pages:HomePage}"
                                       Visibility="{Binding Settings.InternalPlayerEnabled, Converter={StaticResource BoolToVisibleCollapsedConverter}}"/>
                <ui:NavigationViewItem Content="{DynamicResource MediaFlyoutTitle}"
                                       Icon="{ui:SymbolIcon VideoPlayPause24}"
                                       TargetPageType="{x:Type pages:MediaFlyoutPage}"/>
                <ui:NavigationViewItem Content="{DynamicResource TaskbarWidgetCustomizationTitle}"
                                       Icon="{ui:SymbolIcon TextboxAlignBottom24}"
                                       TargetPageType="{x:Type pages:TaskbarWidgetPage}"/>
                <ui:NavigationViewItem Content="{DynamicResource NextUpCustomizationTitle}"
                                       Icon="{ui:SymbolIcon MusicNote2Play20}"
                                       TargetPageType="{x:Type pages:NextUpPage}"/>
                <ui:NavigationViewItem Content="{DynamicResource LockKeysCustomizationTitle}"
                                       Icon="{ui:SymbolIcon LockMultiple24}"
                                       TargetPageType="{x:Type pages:LockKeysPage}"/>
                <ui:NavigationViewItem Content="{DynamicResource TaskbarVisualizerTitle}"
                                       Icon="{ui:SymbolIcon SoundWaveCircle24}"
                                       TargetPageType="{x:Type pages:TaskbarVisualizerPage}"/>
                <ui:NavigationViewItem Content="{DynamicResource SystemSettingsTitle}"
                                       Icon="{ui:SymbolIcon Settings24}"
                                       TargetPageType="{x:Type pages:SystemPage}"/>
            </ui:NavigationView.MenuItems>
            <ui:NavigationView.FooterMenuItems>
            </ui:NavigationView.FooterMenuItems>
        </ui:NavigationView>

        <ui:TitleBar
            x:Name="TitleBar"
            Title="{DynamicResource App_ProductName}"
            Grid.Row="0"
            Height="40">
            <ui:TitleBar.Icon>
                <ui:ImageIcon Source="/Resources/FluentFlyout2.ico"/>
            </ui:TitleBar.Icon>
        </ui:TitleBar>
    </Grid>
</ui:FluentWindow>
