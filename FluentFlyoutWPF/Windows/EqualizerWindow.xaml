<ui:FluentWindow x:Class="FluentFlyoutWPF.Windows.EqualizerWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Icon="pack://application:,,,/Resources/FluentFlyout2.ico"
                 Height="680"
                 Width="480"
                 WindowStartupLocation="CenterOwner"
                 ExtendsContentIntoTitleBar="True"
                 WindowBackdropType="Mica"
                 ResizeMode="NoResize"
                 Background="{DynamicResource ApplicationBackgroundBrush}">

        <Grid>
                <ui:TitleBar Title="{DynamicResource Eq_Title}"
                             VerticalAlignment="Top"/>

                <Grid Margin="24,48,24,24">
                        <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <!-- Header -->
                                <RowDefinition Height="Auto"/>
                                <!-- Sliders -->
                                <RowDefinition Height="*"/>
                                <!-- Presets -->
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Grid Grid.Row="0"
                              Margin="0,0,0,28">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                        <ui:SymbolIcon Symbol="Speaker224"
                                                       FontSize="28"
                                                       Margin="0,0,12,0"/>
                                        <TextBlock Text="{DynamicResource Eq_Title}"
                                                   FontSize="26"
                                                   FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                </StackPanel>
                                <ui:ToggleSwitch x:Name="EqEnabledToggle"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Center"
                                                 IsChecked="True"
                                                 ToolTip="{DynamicResource Eq_Enable}"
                                                 Checked="EqEnabledToggle_Changed"
                                                 Unchecked="EqEnabledToggle_Changed"/>
                        </Grid>

                        <!-- EQ Band Sliders -->
                        <Border Grid.Row="1"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                CornerRadius="12"
                                Padding="16,20"
                                Margin="0,0,0,24"
                                BorderThickness="1"
                                BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}">
                                <StackPanel Orientation="Horizontal"
                                            HorizontalAlignment="Center">
                                        <!-- Band 0: 31Hz -->
                                        <StackPanel Width="36"
                                                    Margin="2,0">
                                                <TextBlock x:Name="GainLabel0"
                                                           Text="0"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,6"/>
                                                <Slider x:Name="BandSlider0"
                                                        Orientation="Vertical"
                                                        Height="140"
                                                        Minimum="-12"
                                                        Maximum="12"
                                                        Value="0"
                                                        SmallChange="0.5"
                                                        LargeChange="1"
                                                        TickFrequency="3"
                                                        IsSnapToTickEnabled="False"
                                                        ValueChanged="BandSlider_ValueChanged"
                                                        Tag="0"/>
                                                <TextBlock Text="31"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="10"
                                                           Margin="0,6,0,0"/>
                                        </StackPanel>
                                        <!-- Band 1: 63Hz -->
                                        <StackPanel Width="36"
                                                    Margin="2,0">
                                                <TextBlock x:Name="GainLabel1"
                                                           Text="0"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,6"/>
                                                <Slider x:Name="BandSlider1"
                                                        Orientation="Vertical"
                                                        Height="140"
                                                        Minimum="-12"
                                                        Maximum="12"
                                                        Value="0"
                                                        SmallChange="0.5"
                                                        LargeChange="1"
                                                        TickFrequency="3"
                                                        IsSnapToTickEnabled="False"
                                                        ValueChanged="BandSlider_ValueChanged"
                                                        Tag="1"/>
                                                <TextBlock Text="63"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="10"
                                                           Margin="0,6,0,0"/>
                                        </StackPanel>
                                        <!-- Band 2: 125Hz -->
                                        <StackPanel Width="36"
                                                    Margin="2,0">
                                                <TextBlock x:Name="GainLabel2"
                                                           Text="0"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,6"/>
                                                <Slider x:Name="BandSlider2"
                                                        Orientation="Vertical"
                                                        Height="140"
                                                        Minimum="-12"
                                                        Maximum="12"
                                                        Value="0"
                                                        SmallChange="0.5"
                                                        LargeChange="1"
                                                        TickFrequency="3"
                                                        IsSnapToTickEnabled="False"
                                                        ValueChanged="BandSlider_ValueChanged"
                                                        Tag="2"/>
                                                <TextBlock Text="125"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="10"
                                                           Margin="0,6,0,0"/>
                                        </StackPanel>
                                        <!-- Band 3: 250Hz -->
                                        <StackPanel Width="36"
                                                    Margin="2,0">
                                                <TextBlock x:Name="GainLabel3"
                                                           Text="0"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,6"/>
                                                <Slider x:Name="BandSlider3"
                                                        Orientation="Vertical"
                                                        Height="140"
                                                        Minimum="-12"
                                                        Maximum="12"
                                                        Value="0"
                                                        SmallChange="0.5"
                                                        LargeChange="1"
                                                        TickFrequency="3"
                                                        IsSnapToTickEnabled="False"
                                                        ValueChanged="BandSlider_ValueChanged"
                                                        Tag="3"/>
                                                <TextBlock Text="250"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="10"
                                                           Margin="0,6,0,0"/>
                                        </StackPanel>
                                        <!-- Band 4: 500Hz -->
                                        <StackPanel Width="36"
                                                    Margin="2,0">
                                                <TextBlock x:Name="GainLabel4"
                                                           Text="0"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,6"/>
                                                <Slider x:Name="BandSlider4"
                                                        Orientation="Vertical"
                                                        Height="140"
                                                        Minimum="-12"
                                                        Maximum="12"
                                                        Value="0"
                                                        SmallChange="0.5"
                                                        LargeChange="1"
                                                        TickFrequency="3"
                                                        IsSnapToTickEnabled="False"
                                                        ValueChanged="BandSlider_ValueChanged"
                                                        Tag="4"/>
                                                <TextBlock Text="500"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="10"
                                                           Margin="0,6,0,0"/>
                                        </StackPanel>
                                        <!-- Band 5: 1kHz -->
                                        <StackPanel Width="36"
                                                    Margin="2,0">
                                                <TextBlock x:Name="GainLabel5"
                                                           Text="0"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,6"/>
                                                <Slider x:Name="BandSlider5"
                                                        Orientation="Vertical"
                                                        Height="140"
                                                        Minimum="-12"
                                                        Maximum="12"
                                                        Value="0"
                                                        SmallChange="0.5"
                                                        LargeChange="1"
                                                        TickFrequency="3"
                                                        IsSnapToTickEnabled="False"
                                                        ValueChanged="BandSlider_ValueChanged"
                                                        Tag="5"/>
                                                <TextBlock Text="1K"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="10"
                                                           Margin="0,6,0,0"/>
                                        </StackPanel>
                                        <!-- Band 6: 2kHz -->
                                        <StackPanel Width="36"
                                                    Margin="2,0">
                                                <TextBlock x:Name="GainLabel6"
                                                           Text="0"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,6"/>
                                                <Slider x:Name="BandSlider6"
                                                        Orientation="Vertical"
                                                        Height="140"
                                                        Minimum="-12"
                                                        Maximum="12"
                                                        Value="0"
                                                        SmallChange="0.5"
                                                        LargeChange="1"
                                                        TickFrequency="3"
                                                        IsSnapToTickEnabled="False"
                                                        ValueChanged="BandSlider_ValueChanged"
                                                        Tag="6"/>
                                                <TextBlock Text="2K"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="10"
                                                           Margin="0,6,0,0"/>
                                        </StackPanel>
                                        <!-- Band 7: 4kHz -->
                                        <StackPanel Width="36"
                                                    Margin="2,0">
                                                <TextBlock x:Name="GainLabel7"
                                                           Text="0"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,6"/>
                                                <Slider x:Name="BandSlider7"
                                                        Orientation="Vertical"
                                                        Height="140"
                                                        Minimum="-12"
                                                        Maximum="12"
                                                        Value="0"
                                                        SmallChange="0.5"
                                                        LargeChange="1"
                                                        TickFrequency="3"
                                                        IsSnapToTickEnabled="False"
                                                        ValueChanged="BandSlider_ValueChanged"
                                                        Tag="7"/>
                                                <TextBlock Text="4K"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="10"
                                                           Margin="0,6,0,0"/>
                                        </StackPanel>
                                        <!-- Band 8: 8kHz -->
                                        <StackPanel Width="36"
                                                    Margin="2,0">
                                                <TextBlock x:Name="GainLabel8"
                                                           Text="0"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,6"/>
                                                <Slider x:Name="BandSlider8"
                                                        Orientation="Vertical"
                                                        Height="140"
                                                        Minimum="-12"
                                                        Maximum="12"
                                                        Value="0"
                                                        SmallChange="0.5"
                                                        LargeChange="1"
                                                        TickFrequency="3"
                                                        IsSnapToTickEnabled="False"
                                                        ValueChanged="BandSlider_ValueChanged"
                                                        Tag="8"/>
                                                <TextBlock Text="8K"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="10"
                                                           Margin="0,6,0,0"/>
                                        </StackPanel>
                                        <!-- Band 9: 16kHz -->
                                        <StackPanel Width="36"
                                                    Margin="2,0">
                                                <TextBlock x:Name="GainLabel9"
                                                           Text="0"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Margin="0,0,0,6"/>
                                                <Slider x:Name="BandSlider9"
                                                        Orientation="Vertical"
                                                        Height="140"
                                                        Minimum="-12"
                                                        Maximum="12"
                                                        Value="0"
                                                        SmallChange="0.5"
                                                        LargeChange="1"
                                                        TickFrequency="3"
                                                        IsSnapToTickEnabled="False"
                                                        ValueChanged="BandSlider_ValueChanged"
                                                        Tag="9"/>
                                                <TextBlock Text="16K"
                                                           HorizontalAlignment="Center"
                                                           Opacity="0.5"
                                                           FontSize="10"
                                                           Margin="0,6,0,0"/>
                                        </StackPanel>
                                </StackPanel>
                        </Border>

                        <!-- Presets Section -->
                        <Grid Grid.Row="2">
                                <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="{DynamicResource Eq_Presets}"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Opacity="0.7"
                                           Margin="4,0,0,12"/>

                                <ScrollViewer Grid.Row="1"
                                              VerticalScrollBarVisibility="Auto">
                                        <UniformGrid x:Name="PresetsGrid"
                                                     Columns="2"/>
                                </ScrollViewer>
                        </Grid>
                </Grid>
        </Grid>
</ui:FluentWindow>
