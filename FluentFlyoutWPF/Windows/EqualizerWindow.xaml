<ui:FluentWindow
    x:Class="FluentFlyoutWPF.Windows.EqualizerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewModels="clr-namespace:FluentFlyoutWPF.ViewModels"
    mc:Ignorable="d"
    Icon="pack://application:,,,/Resources/FluentFlyout2.ico"
    Height="680"
    Width="480"
    WindowStartupLocation="CenterOwner"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Mica"
    ResizeMode="NoResize"
    Background="{DynamicResource ApplicationBackgroundBrush}"
    d:DataContext="{d:DesignInstance viewModels:EqualizerViewModel}">

    <Grid>
        <ui:TitleBar Title="{DynamicResource Eq_Title}"
                     VerticalAlignment="Top"/>

        <Grid Margin="24,48,24,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0"
                  Margin="0,0,0,28">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <ui:SymbolIcon Symbol="Speaker224"
                                   FontSize="28"
                                   Margin="0,0,12,0"/>
                    <TextBlock Text="{DynamicResource Eq_Title}"
                               FontSize="26"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <ui:ToggleSwitch HorizontalAlignment="Right"
                                 VerticalAlignment="Center"
                                 ToolTip="{DynamicResource Eq_Enable}"
                                 IsChecked="{Binding IsEnabled, Mode=TwoWay}"/>
            </Grid>

            <Border Grid.Row="1"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    CornerRadius="12"
                    Padding="16,20"
                    Margin="0,0,0,24"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource SurfaceStrokeColorDefaultBrush}">
                <ItemsControl ItemsSource="{Binding Bands}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type viewModels:EqualizerBandViewModel}">
                            <StackPanel Width="36"
                                        Margin="2,0">
                                <TextBlock Text="{Binding GainLabel}"
                                           HorizontalAlignment="Center"
                                           Opacity="0.5"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,6"/>
                                <Slider Orientation="Vertical"
                                        Height="140"
                                        Minimum="-12"
                                        Maximum="12"
                                        Value="{Binding Gain, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        SmallChange="0.5"
                                        LargeChange="1"
                                        TickFrequency="3"
                                        IsSnapToTickEnabled="False"/>
                                <TextBlock Text="{Binding Label}"
                                           HorizontalAlignment="Center"
                                           Opacity="0.5"
                                           FontSize="10"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="{DynamicResource Eq_Presets}"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Opacity="0.7"
                           Margin="4,0,0,12"/>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Presets}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type viewModels:EqualizerPresetViewModel}">
                                <ui:Button Margin="4"
                                           Padding="16"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           HorizontalContentAlignment="Left"
                                           Appearance="{Binding Appearance}"
                                           Command="{Binding DataContext.ApplyPresetCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                           CommandParameter="{Binding Name}">
                                    <StackPanel HorizontalAlignment="Left">
                                        <ui:SymbolIcon Symbol="{Binding IconSymbol}"
                                                       FontSize="26"
                                                       Margin="0,0,0,10"/>
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"/>
                                    </StackPanel>
                                </ui:Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</ui:FluentWindow>
