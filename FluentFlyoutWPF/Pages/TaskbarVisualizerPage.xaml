<Page x:Class="FluentFlyoutWPF.Pages.TaskbarVisualizerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
      xmlns:viewModels="clr-namespace:FluentFlyoutWPF.ViewModels"
      xmlns:utils="clr-namespace:FluentFlyoutWPF.Classes.Utils"
      mc:Ignorable="d"
      d:DesignHeight="1200"
      d:DesignWidth="800"
      Title="TaskbarVisualizerPage"
      d:DataContext="{d:DesignInstance viewModels:UserSettings}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      d:Background="White">

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Converters.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="1200"
                    Margin="24">
            <ui:TextBlock Text="{DynamicResource TaskbarVisualizerTitle}"
                          FontTypography="Title"
                          Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,24">
                <Border CornerRadius="10"
                        ClipToBounds="True"
                        Width="164"
                        Height="98">
                    <Border.Background>
                        <ImageBrush ImageSource="/Resources/FluentFlyoutTaskbar-NoTitle-Zoomed.png"
                                    Stretch="UniformToFill"/>
                    </Border.Background>
                </Border>
                <TextBlock FontSize="14"
                           FontWeight="Regular"
                           HorizontalAlignment="Stretch"
                           Opacity="0.75"
                           Margin="12,0,0,0"
                           MaxWidth="450"
                           TextWrapping="WrapWithOverflow"
                           Text="{DynamicResource TaskbarVisualizerDescription}"/>
            </StackPanel>

            <!-- Premium Status InfoBar (only shown for Store versions) -->
            <ui:InfoBar Title="{DynamicResource PremiumUnlockedMessage}"
                        Severity="Success"
                        IsClosable="True"
                        Margin="0,0,0,3">
                <ui:InfoBar.Style>
                    <Style TargetType="ui:InfoBar"
                           BasedOn="{StaticResource {x:Type ui:InfoBar}}">
                        <Setter Property="IsOpen"
                                Value="False"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsStoreVersion}"
                                            Value="True"/>
                                    <Condition Binding="{Binding IsPremiumUnlocked}"
                                            Value="True"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="IsOpen"
                                        Value="True"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:InfoBar.Style>
            </ui:InfoBar>

            <!-- Premium Locked InfoBar (only shown for Store versions without premium) -->
            <ui:InfoBar IsOpen="True"
                        Severity="Warning"
                        IsClosable="False"
                        Margin="0,0,0,24">
                <ui:InfoBar.Style>
                    <Style TargetType="ui:InfoBar">
                        <Setter Property="Visibility"
                                Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsStoreVersion}"
                                            Value="True"/>
                                    <Condition Binding="{Binding IsPremiumUnlocked}"
                                            Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility"
                                        Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </ui:InfoBar.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{DynamicResource PremiumLockedMessage}"
                               VerticalAlignment="Center"/>
                    <ui:Button Name="UnlockPremiumButton"
                               Click="UnlockPremiumButton_Click"
                               Appearance="Primary"
                               Margin="12,2,0,2"
                               FontSize="12"
                               CornerRadius="6">
                        <ui:Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource UnlockPremiumButton}"/>
                                <TextBlock Text=" - "/>
                                <TextBlock Text="{Binding PremiumPrice}"/>
                            </StackPanel>
                        </ui:Button.Content>
                    </ui:Button>
                </StackPanel>
            </ui:InfoBar>

            <StackPanel Opacity="{Binding IsPremiumUnlocked, Converter={StaticResource BoolToFullHalfOpacityConverter}}">
                <ui:CardControl Icon="{ui:SymbolIcon SoundWaveCircle24}"
                                Margin="0,0,0,24">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource TaskbarVisualizerEnabledTitle}"
                                           FontSize="14"
                                           FontWeight="Regular"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource TaskbarVisualizerEnabledDescription}"
                                       FontSize="12"
                                       Opacity="0.5"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:ToggleSwitch IsChecked="{Binding TaskbarVisualizerEnabled, Mode=TwoWay}"
                                           IsEnabled="{Binding IsPremiumUnlocked}"/>
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon ArrowMove24}"
                                Margin="0,0,0,3">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{DynamicResource TaskbarVisualizerPositionTitle}"
                                       FontSize="14"
                                       FontWeight="Regular"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ComboBox SelectedIndex="{Binding TaskbarVisualizerPosition}"
                              IsEnabled="{Binding IsPremiumUnlocked}">
                        <ComboBoxItem Content="{DynamicResource PositionBottomLeft}"/>
                        <ComboBoxItem Content="{DynamicResource PositionBottomRight}"/>
                    </ComboBox>
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon DataBarVertical24, Filled=True}"
                                Margin="0,0,0,3">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource TaskbarVisualizerBarCountTitle}"
                                           FontSize="14"
                                           FontWeight="Regular"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource TaskbarVisualizerBarCountDescription}"
                                       FontSize="12"
                                       Opacity="0.5"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <Grid Width="200"
                          Opacity="{Binding IsPremiumUnlocked, Converter={StaticResource BoolToFullHalfOpacityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Slider Grid.Column="0"
                                Minimum="1"
                                Maximum="20"
                                Value="{Binding TaskbarVisualizerBarCount, Mode=TwoWay}"
                                IsEnabled="{Binding IsPremiumUnlocked}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="True"
                                HorizontalAlignment="Stretch"/>
                        <ui:TextBlock Grid.Column="1"
                                      Text="{Binding TaskbarVisualizerBarCount}"
                                      Width="24"
                                      TextAlignment="Center"
                                      Margin="12,0,0,0"/>
                    </Grid>
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon AlignCenterHorizontal24, Filled=True}"
                                Margin="0,0,0,3">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{DynamicResource TaskbarVisualizerCenteredBarsTitle}"
                                       FontSize="14"
                                       FontWeight="Regular"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource TaskbarVisualizerCenteredBarsDescription}"
                                       FontSize="12"
                                       Opacity="0.5"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:ToggleSwitch IsChecked="{Binding TaskbarVisualizerCenteredBars, Mode=TwoWay}"
                                           IsEnabled="{Binding IsPremiumUnlocked}"/>
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon LineHorizontal120, Filled=False}"
                                Margin="0,0,0,12">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{DynamicResource TaskbarVisualizerBaselineTitle}"
                                       FontSize="14"
                                       FontWeight="Regular"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource TaskbarVisualizerBaselineDescription}"
                                       FontSize="12"
                                       Opacity="0.5"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:ToggleSwitch IsChecked="{Binding TaskbarVisualizerBaseline, Mode=TwoWay}"
                                           IsEnabled="{Binding IsPremiumUnlocked}"/>
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon Speaker224, Filled=True}"
                                Margin="0,0,0,12">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{DynamicResource TaskbarVisualizerStereoModeTitle}"
                                       FontSize="14"
                                       FontWeight="Regular"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource TaskbarVisualizerStereoModeDescription}"
                                       FontSize="12"
                                       Opacity="0.5"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <ComboBox SelectedIndex="{Binding TaskbarVisualizerStereoMode}"
                              IsEnabled="{Binding IsPremiumUnlocked}">
                        <ComboBoxItem Content="{DynamicResource TaskbarVisualizerStereoModeMono}"/>
                        <ComboBoxItem Content="{DynamicResource TaskbarVisualizerStereoModeStereoMirror}"/>
                    </ComboBox>
                </ui:CardControl>

                <!-- Audio Calibration Monitor -->
                <ui:Card Padding="16,12,16,16"
                        Margin="0,0,0,24">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,16">
                            <ui:SymbolIcon Symbol="SoundWaveCircle24"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource TaskbarVisualizer_CalibrationTitle}"
                                        FontSize="14"
                                        FontWeight="SemiBold"/>
                                <TextBlock Text="{DynamicResource TaskbarVisualizer_CalibrationDescription}"
                                        FontSize="12"
                                        Opacity="0.6"/>
                            </StackPanel>
                        </StackPanel>

                        <Grid Height="40"
                                Margin="0,0,0,8">
                            <Border Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    CornerRadius="6"/>
                            <ProgressBar Value="{Binding TaskbarVisualizerCurrentLevel}"
                                         Minimum="0"
                                         Maximum="100"
                                         Height="16"
                                         VerticalAlignment="Center"
                                         Margin="8,0"
                                         Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Opacity="0.5"/>

                            <ProgressBar Value="{Binding TaskbarVisualizerCalibratedLevel}"
                                         Minimum="0"
                                         Maximum="100"
                                         Height="6"
                                         VerticalAlignment="Center"
                                         Margin="8,0"
                                         Foreground="{DynamicResource AccentFillColorDefaultBrush}"
                                         Background="Transparent"
                                         BorderThickness="0"/>

                            <!-- Markers Overlay -->
                            <Grid Margin="8,0">
                                <!-- Sensitivity Marker -->
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding TaskbarVisualizerAudioSensitivity, Converter={StaticResource SensitivityToGridLengthConverter}}"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="1"
                                            Width="3"
                                            Height="28"
                                            Background="#FF4CAF50"
                                            CornerRadius="1.5"
                                            ToolTip="{DynamicResource TaskbarVisualizer_StartPoint}"/>
                                </Grid>

                                <!-- Peak Level Marker -->
                                <Grid HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding TaskbarVisualizerAudioPeakLevel, Converter={StaticResource PeakLevelToGridLengthConverter}}"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="1"
                                            Width="3"
                                            Height="28"
                                            Background="#FFF44336"
                                            CornerRadius="1.5"
                                            ToolTip="{DynamicResource TaskbarVisualizer_PeakThreshold}"/>
                                </Grid>
                            </Grid>
                        </Grid>

                        <Grid Margin="8,0">
                            <TextBlock Text="{DynamicResource TaskbarVisualizer_Silence}"
                                    FontSize="10"
                                    Opacity="0.5"
                                    HorizontalAlignment="Left"/>
                            <TextBlock Text="{DynamicResource TaskbarVisualizer_Max}"
                                    FontSize="10"
                                    Opacity="0.5"
                                    HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>
                </ui:Card>

                <ui:CardControl Icon="{ui:SymbolIcon BezierCurveSquare20, Filled=False}"
                                Margin="0,0,0,3">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <TextBlock Text="{DynamicResource TaskbarVisualizerAudioSensitivityTitle}"
                                       FontSize="14"
                                       FontWeight="Regular"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource TaskbarVisualizerAudioSensitivityDescription}"
                                       FontSize="12"
                                       Opacity="0.5"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <Grid Width="220"
                          Opacity="{Binding IsPremiumUnlocked, Converter={StaticResource BoolToFullHalfOpacityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Grid.Column="0"
                                       Symbol="Subtract24"
                                       Width="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        <Slider Grid.Column="1"
                                Minimum="1"
                                Maximum="10"
                                Value="{Binding TaskbarVisualizerAudioSensitivity, Mode=TwoWay}"
                                IsEnabled="{Binding IsPremiumUnlocked}"
                                TickFrequency="1"
                                TickPlacement="Both"
                                IsSnapToTickEnabled="True"
                                HorizontalAlignment="Stretch"
                                Margin="12,0,12,0"/>
                        <ui:SymbolIcon Grid.Column="2"
                                       Symbol="Add24"
                                       Width="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                    </Grid>
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon ArrowAutofitUp24, Filled=False}"
                                Margin="0,0,0,3">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource TaskbarVisualizerAudioPeakLevelTitle}"
                                           FontSize="14"
                                           FontWeight="Regular"
                                           VerticalAlignment="Center"/>
                                <ui:InfoBadge Value="{DynamicResource General_NewLabel}"
                                              FontWeight="Medium"
                                              FontSize="10"
                                              Margin="6,-2,0,-2"
                                              Severity="Success"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource TaskbarVisualizerAudioPeakLevelDescription}"
                                       FontSize="12"
                                       Opacity="0.5"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <Grid Width="220"
                          Opacity="{Binding IsPremiumUnlocked, Converter={StaticResource BoolToFullHalfOpacityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ui:SymbolIcon Grid.Column="0"
                                       Symbol="Subtract24"
                                       Width="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        <Slider Grid.Column="1"
                                Minimum="1"
                                Maximum="10"
                                Value="{Binding TaskbarVisualizerAudioPeakLevel, Mode=TwoWay}"
                                IsEnabled="{Binding IsPremiumUnlocked}"
                                TickFrequency="1"
                                TickPlacement="Both"
                                IsSnapToTickEnabled="True"
                                HorizontalAlignment="Stretch"
                                Margin="12,0,12,0"/>
                        <ui:SymbolIcon Grid.Column="2"
                                       Symbol="Add24"
                                       Width="24"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                    </Grid>
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon Speaker224}"
                                Margin="0,0,0,12">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <TextBlock FontSize="14"
                                       FontWeight="Regular"
                                       VerticalAlignment="Center">
                                <Hyperlink x:Name="StartupHyperlink"
                                           NavigateUri="ms-settings:apps-volume"
                                           BaselineAlignment="Center"
                                           RequestNavigate="StartupHyperlink_RequestNavigate"
                                           TextDecorations="None"
                                           Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}">
                                    <Run Text="{DynamicResource TaskbarVisualizerOutputDeviceTitle}"/>
                                    <ui:SymbolIcon VerticalAlignment="Center"
                                                   FontSize="14"
                                                   Symbol="ArrowUpRight24"/>
                                </Hyperlink>
                            </TextBlock>
                            <TextBlock Text="{DynamicResource TaskbarVisualizerOutputDeviceDescription}"
                                       FontSize="12"
                                       Opacity="0.5"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                </ui:CardControl>

                <ui:CardControl Icon="{ui:SymbolIcon ExpandUpRight24}"
                                Margin="0,0,0,76">
                    <ui:CardControl.Header>
                        <StackPanel Orientation="Vertical">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource TaskbarVisualizerClickableTitle}"
                                           FontSize="14"
                                           FontWeight="Regular"
                                           VerticalAlignment="Center"/>
                                <ui:InfoBadge Value="{DynamicResource General_NewLabel}"
                                              FontWeight="Medium"
                                              FontSize="10"
                                              Margin="6,-2,0,-2"
                                              Severity="Success"/>
                            </StackPanel>
                            <TextBlock Text="{DynamicResource TaskbarVisualizerClickableDescription}"
                                       FontSize="12"
                                       Opacity="0.5"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:ToggleSwitch IsChecked="{Binding TaskbarVisualizerClickable, Mode=TwoWay}"
                                           IsEnabled="{Binding IsPremiumUnlocked}"/>
                </ui:CardControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
    