<Page x:Class="FluentFlyoutWPF.Pages.LibraryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:models="clr-namespace:FluentFlyoutWPF.Models"
      xmlns:classes="clr-namespace:FluentFlyoutWPF.Classes"
      xmlns:controls="clr-namespace:FluentFlyoutWPF.Controls"
      xmlns:behaviors="clr-namespace:FluentFlyoutWPF.Classes.Behaviors"
      xmlns:utils="clr-namespace:FluentFlyoutWPF.Classes.Utils"
      xmlns:viewModels="clr-namespace:FluentFlyoutWPF.ViewModels"
      xmlns:settings="clr-namespace:FluentFlyout.Classes.Settings"
      mc:Ignorable="d"
      d:DesignHeight="800"
      d:DesignWidth="1200"
      Title="LibraryPage"
      d:DataContext="{d:DesignInstance viewModels:UserSettings}"
      d:Background="White"
      x:Name="PageRoot"
      behaviors:DisableAncestorScrollBehavior.DisableVerticalAncestorScroll="True"
      behaviors:FrameworkElementCommandBehavior.LoadedCommand="{Binding InitializeViewCommand}"
      ScrollViewer.VerticalScrollBarVisibility="Disabled">

    <Page.Background>
        <SolidColorBrush Color="Transparent"/>
    </Page.Background>

    <Page.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Converters.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <classes:PathToImageConverter x:Key="PathToImageConverter"/>
            <utils:HalfValueConverter x:Key="HalfValueConverter"/>

            <!-- Global Styles -->
            <Style TargetType="ContextMenu"
                   BasedOn="{StaticResource {x:Type ContextMenu}}">
                <Setter Property="Padding"
                        Value="4"/>
                <Setter Property="Background"
                        Value="{DynamicResource MenuFlyoutPresenterBackground}"/>
                <Setter Property="Foreground"
                        Value="{DynamicResource TextFillColorPrimaryBrush}"/>
                <Setter Property="BorderBrush"
                        Value="{DynamicResource SurfaceStrokeColorDefaultBrush}"/>
                <Setter Property="BorderThickness"
                        Value="1"/>
            </Style>

            <Style TargetType="MenuItem"
                   BasedOn="{StaticResource {x:Type MenuItem}}">
                <Setter Property="Padding"
                        Value="8,4"/>
            </Style>

            <Style x:Key="AnimatedListViewStyle"
                   TargetType="ListView"
                   BasedOn="{StaticResource {x:Type ListView}}">
                <Setter Property="RenderTransform">
                    <Setter.Value>
                        <TranslateTransform X="0"
                                            Y="0"/>
                    </Setter.Value>
                </Setter>
                <Style.Triggers>
                    <Trigger Property="IsVisible"
                             Value="True">
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     From="0"
                                                     To="1"
                                                     Duration="0:0:0.25"/>
                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                     From="-30"
                                                     To="0"
                                                     Duration="0:0:0.4">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <ContextMenu x:Key="TrackItemContextMenu">
                <MenuItem Header="{DynamicResource Lib_ContextMenu_Play}"
                          Command="{Binding PlacementTarget.Tag.PlayTrackCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                    <MenuItem.Icon>
                        <ui:SymbolIcon Symbol="Play24"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{DynamicResource Lib_ContextMenu_AddToQueue}"
                          Command="{Binding PlacementTarget.Tag.AddToQueueCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                    <MenuItem.Icon>
                        <ui:SymbolIcon Symbol="AddSquare24"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{DynamicResource Lib_ContextMenu_Edit}"
                          Command="{Binding PlacementTarget.Tag.EditTrackCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                    <MenuItem.Icon>
                        <ui:SymbolIcon Symbol="Edit24"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{DynamicResource Lib_ContextMenu_OpenFileLocation}"
                          Command="{Binding PlacementTarget.Tag.OpenTrackLocationCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                    <MenuItem.Icon>
                        <ui:SymbolIcon Symbol="FolderOpen24"/>
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>

        </ResourceDictionary>
    </Page.Resources>

    <Grid HorizontalAlignment="Stretch"
          Margin="{Binding ElementName=PageRoot, Path=ActualWidth, Converter={StaticResource ResponsivePageMarginConverter}}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Controles Fijos (Header + Tabs + Search) -->
        <StackPanel Grid.Row="0"
                    Margin="0,0,0,16">

            <!-- Header Level: Título, Búsqueda y Acciones Globales -->
            <Grid Margin="0,12,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <ui:TextBlock FontTypography="Title"
                              Text="{DynamicResource Lib_Title}"
                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                              VerticalAlignment="Center"/>

                <!-- Search Box centrado y espacioso -->
                <ui:TextBox Grid.Column="1"
                            x:Name="SearchBox"
                            PlaceholderText="{DynamicResource Lib_SearchPlaceholder}"
                            Icon="{ui:SymbolIcon Search24}"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                            MaxWidth="{Binding ElementName=PageRoot, Path=ActualWidth, Converter={StaticResource ResponsiveSearchWidthConverter}}"
                            HorizontalAlignment="Left"
                            Margin="24,0,0,0"/>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            Margin="0,0,12,0">
                    <ui:TextBlock Text="{DynamicResource Lib_SortBy}"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"
                                  Opacity="0.6"
                                  FontSize="12"/>
                    <ui:DropDownButton x:Name="SortButton"
                                       Content="{DynamicResource Lib_Sort_Title}"
                                       Margin="0,0,4,0">
                        <ui:DropDownButton.Flyout>
                            <ContextMenu>
                                <MenuItem Header="{DynamicResource Lib_Sort_Title}"
                                          Tag="Title"
                                          Command="{Binding ApplySortPropertyFromMenuCommand}"
                                          CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}"/>
                                <MenuItem Header="{DynamicResource Lib_Sort_Artist}"
                                          Tag="Artist"
                                          Command="{Binding ApplySortPropertyFromMenuCommand}"
                                          CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}"/>
                                <MenuItem Header="{DynamicResource Lib_Sort_Album}"
                                          Tag="Album"
                                          Command="{Binding ApplySortPropertyFromMenuCommand}"
                                          CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}"/>
                                <MenuItem Header="{DynamicResource Lib_Sort_Duration}"
                                          Tag="Duration"
                                          Command="{Binding ApplySortPropertyFromMenuCommand}"
                                          CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}"/>
                                <MenuItem Header="{DynamicResource Lib_Sort_PlayCount}"
                                          Tag="PlayCount"
                                          Command="{Binding ApplySortPropertyFromMenuCommand}"
                                          CommandParameter="{Binding Tag, RelativeSource={RelativeSource Self}}"/>
                            </ContextMenu>
                        </ui:DropDownButton.Flyout>
                    </ui:DropDownButton>

                    <ui:Button x:Name="SortDirectionBtn"
                               Command="{Binding ToggleSortDirectionCommand}"
                               Padding="0"
                               Width="32"
                               Height="32"
                               Appearance="Transparent"
                               ToolTip="{DynamicResource Lib_SortDirection}">
                        <ui:SymbolIcon x:Name="SortDirectionIcon"
                                       Symbol="{Binding SortDirectionSymbol}"/>
                    </ui:Button>

                    <Separator Margin="8,0"
                               Visibility="Visible"/>

                    <!-- Lyrics Filter -->
                    <ToggleButton x:Name="LyricsFilterBtn"
                                  IsChecked="{Binding Settings.LibraryLyricsFilterEnabled, Mode=TwoWay}"
                                  Command="{Binding ToggleLyricsFilterCommand}"
                                  Style="{StaticResource AccentIconToggleStyle}"
                                  Width="32"
                                  Height="32"
                                  Padding="0"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  ToolTip="{DynamicResource Lib_LyricsFilterTooltip}">
                        <ui:SymbolIcon Symbol="TextBulletListLtr24"
                                       Opacity="{Binding Settings.LibraryLyricsFilterEnabled, Converter={StaticResource BoolToFullHalfOpacityConverter}}"/>
                    </ToggleButton>
                </StackPanel>

                <!-- View Settings (Appearance) -->
                <ui:DropDownButton Grid.Column="3"
                                   Icon="{ui:SymbolIcon Settings24}"
                                   ToolTip="{DynamicResource Lib_ViewSettingsTooltip}"
                                   Appearance="Transparent"
                                   Margin="0,0,8,0">
                    <ui:DropDownButton.Flyout>
                        <ContextMenu x:Name="ViewSettingsContextMenu"
                                     Padding="12,8">
                            <MenuItem Header="{DynamicResource Lib_AppearanceTitle}"
                                      IsEnabled="False"
                                      FontWeight="Bold"/>
                            <Separator/>
                            <MenuItem Header="{DynamicResource Lib_GridSizeTitle}">
                                <MenuItem.Template>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border Background="Transparent">
                                            <StackPanel Margin="12,8">
                                                <TextBlock Text="{DynamicResource Lib_GridSizeDescription}"
                                                           FontSize="11"
                                                           Opacity="0.6"
                                                           Margin="0,0,0,4"/>
                                                <Grid Width="180">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Slider Minimum="120"
                                                            Maximum="280"
                                                            Value="{Binding Settings.LibraryGridItemSize, Mode=TwoWay}"
                                                            TickFrequency="10"
                                                            IsSnapToTickEnabled="True"
                                                            VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Settings.LibraryGridItemSize}"
                                                               Margin="8,0,0,0"
                                                               Width="24"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </MenuItem.Template>
                            </MenuItem>
                            <MenuItem Header="{DynamicResource Lib_IconSizeTitle}">
                                <MenuItem.Template>
                                    <ControlTemplate TargetType="MenuItem">
                                        <Border Background="Transparent">
                                            <StackPanel Margin="12,8">
                                                <TextBlock Text="{DynamicResource Lib_IconSizeDescription}"
                                                           FontSize="11"
                                                           Opacity="0.6"
                                                           Margin="0,0,0,4"/>
                                                <Grid Width="180">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Slider Minimum="32"
                                                            Maximum="72"
                                                            Value="{Binding Settings.LibraryTrackIconSize, Mode=TwoWay}"
                                                            TickFrequency="4"
                                                            IsSnapToTickEnabled="True"
                                                            VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Settings.LibraryTrackIconSize}"
                                                               Margin="8,0,0,0"
                                                               Width="24"
                                                               FontSize="11"
                                                               VerticalAlignment="Center"/>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </MenuItem.Template>
                            </MenuItem>
                            <Separator/>
                            <MenuItem Header="{DynamicResource Lib_ResetAppearance}"
                                      Command="{Binding ResetAppearanceCommand}">
                                <MenuItem.Icon>
                                    <ui:SymbolIcon Symbol="ArrowSync24"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </ui:DropDownButton.Flyout>
                </ui:DropDownButton>

                <ui:Button Grid.Column="4"
                           Content="{DynamicResource Lib_Folders}"
                           Icon="{ui:SymbolIcon FolderAdd24}"
                           Command="{Binding OpenLibraryFoldersCommand}"
                           Appearance="Secondary"/>
            </Grid>

            <!-- Navigation Card: Tabs and Playback Controls -->
            <ui:Card Padding="4"
                     Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="SongsTab"
                                     Content="{DynamicResource Lib_Songs}"
                                     IsChecked="{Binding Settings.LibrarySelectedTab, Converter={StaticResource EqualityToBoolConverter}, ConverterParameter=0, Mode=TwoWay}"
                                     Style="{StaticResource AccentSegmentedTabStyle}"
                                     Padding="16,6"
                                     Margin="0,0,4,0"/>
                        <RadioButton x:Name="AlbumsTab"
                                     Content="{DynamicResource Lib_Albums}"
                                     IsChecked="{Binding Settings.LibrarySelectedTab, Converter={StaticResource EqualityToBoolConverter}, ConverterParameter=1, Mode=TwoWay}"
                                     Style="{StaticResource AccentSegmentedTabStyle}"
                                     Padding="16,6"
                                     Margin="0,0,4,0"/>
                        <RadioButton x:Name="ArtistsTab"
                                     Content="{DynamicResource Lib_Artists}"
                                     IsChecked="{Binding Settings.LibrarySelectedTab, Converter={StaticResource EqualityToBoolConverter}, ConverterParameter=2, Mode=TwoWay}"
                                     Style="{StaticResource AccentSegmentedTabStyle}"
                                     Padding="16,6"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal">
                        <!-- Botón de Reproducir Todo -->
                        <ui:Button Content="{DynamicResource Lib_PlayAll}"
                                   Icon="{ui:SymbolIcon Play24}"
                                   Command="{Binding PlayVisibleTracksCommand}"
                                   Appearance="Primary"
                                   Margin="0,0,8,0"/>

                        <!-- Botón de Cargar Lista -->
                        <ui:Button Content="{DynamicResource Playlist_LoadQueue}"
                                   Icon="{ui:SymbolIcon FolderOpen24}"
                                   Command="{Binding LoadPlaylistCommand}"
                                   Appearance="Secondary"
                                   Margin="0,0,8,0"/>

                        <!-- Botón de Guardar Lista -->
                        <ui:Button Content="{DynamicResource Playlist_SaveQueue}"
                                   Icon="{ui:SymbolIcon Save24}"
                                   Command="{Binding SavePlaylistCommand}"
                                   Appearance="Secondary"
                                   Margin="0,0,8,0"/>

                        <!-- Botón de Aleatorio (Toggle de estado) -->
                        <ui:Button x:Name="ShuffleBtn"
                                   Command="{Binding ToggleShuffleCommand}"
                                   ToolTip="{DynamicResource Lib_Shuffle}"
                                   Width="36"
                                   Height="36"
                                   Padding="0"
                                   Appearance="Transparent"
                                   Margin="0,0,4,0">
                            <ui:SymbolIcon x:Name="ShuffleIcon"
                                           Symbol="{Binding ShuffleSymbol}"/>
                        </ui:Button>

                        <!-- Toggle Playlist Button -->
                        <ToggleButton x:Name="TogglePlaylistBtn"
                                      IsChecked="{Binding Settings.LibraryPlaylistVisible, Mode=TwoWay}"
                                      Style="{StaticResource AccentIconToggleStyle}"
                                      Width="36"
                                      Height="36"
                                      Padding="0"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      ToolTip="{DynamicResource Lib_ToggleList}">
                            <ui:SymbolIcon Symbol="Collections24"
                                           Opacity="{Binding Settings.LibraryPlaylistVisible, Converter={StaticResource BoolToFullHalfOpacityConverter}}"/>
                        </ToggleButton>
                    </StackPanel>
                </Grid>
            </ui:Card>
        </StackPanel>

        <!-- Área de Contenido Scrolleable -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  Margin="0,0,8,0">
                <!-- SONGS VIEW -->
                <ListView x:Name="TracksListView"
                          Style="{StaticResource AnimatedListViewStyle}"
                          ItemsSource="{Binding TracksView}"
                          behaviors:ListViewScrollIntoViewBehavior.ScrollTarget="{Binding RequestedScrollItem}"
                          Visibility="{Binding IsChecked, ElementName=SongsTab, Converter={StaticResource BoolToVisibleCollapsedConverter}}"
                          SelectionMode="Single"
                          Background="Transparent"
                          BorderThickness="0"
                          HorizontalContentAlignment="Stretch"
                          VerticalContentAlignment="Center"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.CanContentScroll="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          VirtualizingPanel.CacheLength="6"
                          VirtualizingPanel.CacheLengthUnit="Item">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <!-- Double-click plays the track (DataContext is the TrackModel) -->
                            <EventSetter Event="MouseDoubleClick"
                                    Handler="TrackItem_MouseDoubleClick"/>
                            <Setter Property="ContextMenu"
                                    Value="{StaticResource TrackItemContextMenu}"/>
                            <!-- Bind Tag to PageRoot's DataContext (the ViewModel) -->
                            <Setter Property="Tag"
                                    Value="{Binding DataContext, ElementName=PageRoot}"/>
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment"
                                    Value="Center"/>
                            <Setter Property="Padding"
                                    Value="12,8"/>
                            <Setter Property="Margin"
                                    Value="0,0,0,4"/>
                            <Setter Property="Cursor"
                                    Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border x:Name="ItemBorder"
                                                CornerRadius="{Binding DataContext.Settings.LibraryItemCornerRadius, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                Background="Transparent"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter TargetName="ItemBorder"
                                                        Property="Background"
                                                        Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected"
                                                     Value="True">
                                                <Setter TargetName="ItemBorder"
                                                        Property="Background"
                                                        Value="{DynamicResource AccentFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:TrackModel}">
                            <Grid Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0"
                                        Width="{Binding DataContext.Settings.LibraryTrackIconSize, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                        Height="{Binding DataContext.Settings.LibraryTrackIconSize, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                        Margin="0,0,12,0"
                                        CornerRadius="{Binding DataContext.Settings.LibraryItemCornerRadius, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8"
                                                          Opacity="0.15"
                                                          ShadowDepth="2"
                                                          Direction="270"/>
                                    </Border.Effect>
                                    <Border CornerRadius="{Binding DataContext.Settings.LibraryItemCornerRadius, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                            ClipToBounds="True">
                                        <Grid>
                                            <ui:SymbolIcon Symbol="MusicNote124"
                                                           Opacity="0.3"
                                                           FontSize="20"/>
                                            <Border CornerRadius="{Binding DataContext.Settings.LibraryItemCornerRadius, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                    RenderOptions.BitmapScalingMode="HighQuality">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding AlbumArtPath, Converter={StaticResource PathToImageConverter}, ConverterParameter=120, Mode=OneWay}"
                                                                Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Border>
                                <StackPanel Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Margin="16,0,0,0">
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,2,0,0">
                                        <Border Visibility="{Binding HasLyrics, Converter={StaticResource BoolToVisibleCollapsedConverter}}"
                                                BorderThickness="1"
                                                BorderBrush="{DynamicResource SystemAccentColorPrimaryBrush}"
                                                CornerRadius="3"
                                                Padding="4,0"
                                                Margin="0,0,8,0"
                                                VerticalAlignment="Center"
                                                Height="14"
                                                Background="Transparent">
                                            <TextBlock Text="{DynamicResource Lib_LyricsBadge}"
                                                       FontSize="8"
                                                       FontWeight="Black"
                                                       Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                                       VerticalAlignment="Center"
                                                       SnapsToDevicePixels="True"/>
                                        </Border>
                                        <TextBlock Text="{Binding Artist}"
                                                   FontSize="12"
                                                   Opacity="0.6"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                                <StackPanel Grid.Column="2"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Duration, StringFormat={}{0:mm\\:ss}}"
                                               Opacity="0.5"
                                               FontSize="12"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- ALBUMS VIEW -->
                <ListView x:Name="AlbumsListView"
                          Style="{StaticResource AnimatedListViewStyle}"
                          ItemsSource="{Binding AlbumsView}"
                          behaviors:ListViewScrollIntoViewBehavior.ScrollTarget="{Binding RequestedScrollItem}"
                          Visibility="{Binding IsChecked, ElementName=AlbumsTab, Converter={StaticResource BoolToVisibleCollapsedConverter}}"
                          Background="Transparent"
                          BorderThickness="0"
                          HorizontalContentAlignment="Left"
                          VerticalContentAlignment="Top"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.CanContentScroll="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          VirtualizingPanel.CacheLength="2"
                          VirtualizingPanel.CacheLengthUnit="Page"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          Padding="0,0,0,20">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment"
                                    Value="Stretch"/>
                            <Setter Property="Padding"
                                    Value="4"/>
                            <Setter Property="Margin"
                                    Value="4"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border CornerRadius="{Binding DataContext.Settings.LibraryItemCornerRadius, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                Background="Transparent"
                                                x:Name="ContainerBorder">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter TargetName="ContainerBorder"
                                                        Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ui:VirtualizingWrapPanel Orientation="Horizontal"
                                                      IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="{Binding DataContext.Settings.LibraryGridItemSize, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                  Margin="8"
                                  Cursor="Hand">
                                <Grid.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SelectAlbumCommand, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                  CommandParameter="{Binding}"/>
                                </Grid.InputBindings>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border x:Name="ArtBorder"
                                        Grid.Row="0"
                                        Height="{Binding DataContext.Settings.LibraryGridItemSize, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                        CornerRadius="{Binding DataContext.Settings.LibraryItemCornerRadius, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                        ClipToBounds="True"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8"
                                                          Opacity="0.15"
                                                          ShadowDepth="2"
                                                          Direction="270"/>
                                    </Border.Effect>
                                    <Border CornerRadius="{Binding DataContext.Settings.LibraryItemCornerRadius, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                            ClipToBounds="True">
                                        <Grid>
                                            <ui:SymbolIcon Symbol="Album24"
                                                           Opacity="0.1"
                                                           FontSize="48"/>
                                            <Border CornerRadius="{Binding DataContext.Settings.LibraryItemCornerRadius, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                    RenderOptions.BitmapScalingMode="HighQuality"
                                                    RenderOptions.CachingHint="Cache">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding ArtPath, Converter={StaticResource PathToImageConverter}, ConverterParameter=250, Mode=OneWay}"
                                                                Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>

                                            <Border x:Name="Overlay"
                                                    Background="#40000000"
                                                    Opacity="0">
                                                <ui:SymbolIcon Symbol="Play24"
                                                               Foreground="White"
                                                               FontSize="32"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Border>

                                <StackPanel Grid.Row="1"
                                            VerticalAlignment="Top"
                                            Margin="0,12,0,0">
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Artist}"
                                               Opacity="0.6"
                                               FontSize="12"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                            <DataTemplate.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter TargetName="Overlay"
                                            Property="Opacity"
                                            Value="1"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- ARTISTS VIEW -->
                <ListView x:Name="ArtistsListView"
                          Style="{StaticResource AnimatedListViewStyle}"
                          ItemsSource="{Binding ArtistsView}"
                          behaviors:ListViewScrollIntoViewBehavior.ScrollTarget="{Binding RequestedScrollItem}"
                          Visibility="{Binding IsChecked, ElementName=ArtistsTab, Converter={StaticResource BoolToVisibleCollapsedConverter}}"
                          Background="Transparent"
                          BorderThickness="0"
                          HorizontalContentAlignment="Left"
                          VerticalContentAlignment="Top"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          ScrollViewer.CanContentScroll="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          VirtualizingPanel.CacheLength="2"
                          VirtualizingPanel.CacheLengthUnit="Page"
                          VirtualizingPanel.ScrollUnit="Pixel"
                          Padding="0,0,0,20">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment"
                                    Value="Stretch"/>
                            <Setter Property="VerticalContentAlignment"
                                    Value="Stretch"/>
                            <Setter Property="Padding"
                                    Value="4"/>
                            <Setter Property="Margin"
                                    Value="4"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <Border CornerRadius="{Binding DataContext.Settings.LibraryItemCornerRadius, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                Background="Transparent"
                                                x:Name="ContainerBorder">
                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver"
                                                     Value="True">
                                                <Setter TargetName="ContainerBorder"
                                                        Property="Background"
                                                        Value="{DynamicResource SubtleFillColorSecondaryBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemsPanel>
                        <ItemsPanelTemplate>
                            <ui:VirtualizingWrapPanel Orientation="Horizontal"
                                                      IsItemsHost="True"/>
                        </ItemsPanelTemplate>
                    </ListView.ItemsPanel>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Width="{Binding DataContext.Settings.LibraryGridItemSize, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                  Margin="8"
                                  Cursor="Hand">
                                <Grid.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding DataContext.SelectArtistCommand, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                  CommandParameter="{Binding}"/>
                                </Grid.InputBindings>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <Border x:Name="ArtBorder"
                                        Grid.Row="0"
                                        Height="{Binding DataContext.Settings.LibraryGridItemSize, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                        CornerRadius="{Binding DataContext.Settings.LibraryItemCornerRadius, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                        ClipToBounds="True"
                                        Background="{DynamicResource ControlFillColorDefaultBrush}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8"
                                                          Opacity="0.15"
                                                          ShadowDepth="2"
                                                          Direction="270"/>
                                    </Border.Effect>
                                    <Border CornerRadius="{Binding DataContext.Settings.LibraryItemCornerRadius, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                            ClipToBounds="True">
                                        <Grid>
                                            <ui:SymbolIcon Symbol="Person24"
                                                           Opacity="0.1"
                                                           FontSize="48"/>
                                            <Border CornerRadius="{Binding DataContext.Settings.LibraryItemCornerRadius, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                                    RenderOptions.BitmapScalingMode="HighQuality"
                                                    RenderOptions.CachingHint="Cache">
                                                <Border.Background>
                                                    <ImageBrush ImageSource="{Binding ArtPath, Converter={StaticResource PathToImageConverter}, ConverterParameter=250, Mode=OneWay}"
                                                                Stretch="UniformToFill"/>
                                                </Border.Background>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Border>

                                <StackPanel Grid.Row="1"
                                            VerticalAlignment="Top"
                                            Margin="0,12,0,0">
                                    <TextBlock Text="{Binding Name}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               HorizontalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Opacity="0.6"
                                               FontSize="12"
                                               HorizontalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0">
                                        <Run Text="{Binding Songs.Count, Mode=OneWay}"/><Run Text=" "/><Run Text="{DynamicResource Lib_Songs}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Grid>
                            <DataTemplate.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter TargetName="ArtBorder"
                                            Property="Opacity"
                                            Value="0.8"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <!-- Alphabetical Index Sidebar -->
            <ItemsControl x:Name="AlphabetIndex"
                          Grid.Column="1"
                          ItemsSource="{Binding AlphabetIndex}"
                          VerticalAlignment="Center"
                          Margin="0,0,8,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:Button Content="{Binding}"
                                   Appearance="Transparent"
                                   Padding="4,1"
                                   Margin="0,1"
                                   MinHeight="18"
                                   MinWidth="24"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Cursor="Hand"
                                   Command="{Binding DataContext.ScrollToLetterCommand, RelativeSource={RelativeSource AncestorType={x:Type Page}}}"
                                   CommandParameter="{Binding}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Playlist -->
            <controls:PlaylistControl x:Name="PlaylistControl"
                                      Grid.Column="2"
                                      Width="{Binding ElementName=PageRoot, Path=ActualWidth, Converter={StaticResource ResponsiveSidePanelWidthConverter}}"
                                      VerticalAlignment="Stretch"
                                      Visibility="{Binding Settings.LibraryPlaylistVisible, Converter={StaticResource BoolToVisibleCollapsedConverter}}"
                                      CloseCommand="{Binding HidePlaylistCommand}"/>

            <Border Grid.ColumnSpan="3"
                    Background="{DynamicResource SolidBackgroundFillColorBaseBrush}"
                    Opacity="0.85"
                    Visibility="{Binding IsLibraryLoading, Converter={StaticResource BoolToVisibleCollapsedConverter}}"
                    Panel.ZIndex="50">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <ui:ProgressRing IsIndeterminate="True"
                                     Width="42"
                                     Height="42"
                                     Margin="0,0,0,12"/>
                    <TextBlock Text="{DynamicResource Lib_Title}"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Cargando biblioteca..."
                               Opacity="0.7"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
