<Page x:Class="FluentFlyoutWPF.Pages.MediaFlyoutPage"
      x:Name="PageRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:controls="clr-namespace:MicaWPF.Controls;assembly=MicaWPF"
      xmlns:viewModels="clr-namespace:FluentFlyoutWPF.ViewModels"
      xmlns:classes="clr-namespace:FluentFlyout.Classes"
      mc:Ignorable="d"
      d:DesignHeight="1600"
      d:DesignWidth="800"
      Title="MediaFlyoutPage"
      d:DataContext="{d:DesignInstance viewModels:UserSettings}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      d:Background="White">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- Custom Style for Backdrop Style Selection Cards -->
        <Style x:Key="BackdropStyleCardItem"
               TargetType="ListBoxItem">
            <Setter Property="Background"
                    Value="{DynamicResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush"
                    Value="{DynamicResource CardStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="Padding"
                    Value="12"/>
            <Setter Property="Margin"
                    Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="CardBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True"
                                Cursor="Hand">
                            <Grid>
                                <ContentPresenter/>
                                <!-- Selection Badge/Border indicator -->
                                <Border x:Name="SelectionBadge"
                                        Width="16"
                                        Height="16"
                                        CornerRadius="8"
                                        Background="{DynamicResource AccentFillColorDefaultBrush}"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="-4,-4,0,0"
                                        Visibility="Collapsed">
                                    <ui:SymbolIcon Symbol="Checkmark12"
                                                   Foreground="White"
                                                   FontSize="9"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="CardBorder"
                                        Property="Background"
                                        Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                <Setter TargetName="CardBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource ControlStrokeColorDefaultBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected"
                                     Value="True">
                                <Setter TargetName="CardBorder"
                                        Property="BorderBrush"
                                        Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                                <Setter TargetName="CardBorder"
                                        Property="Background"
                                        Value="{DynamicResource ControlFillColorSecondaryBrush}"/>
                                <Setter TargetName="SelectionBadge"
                                        Property="Visibility"
                                        Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer x:Name="PageScrollViewer"
                      VerticalScrollBarVisibility="Visible"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False"
                      PanningMode="VerticalOnly"
                      Padding="0,0,10,0">
            <StackPanel DataContext="{Binding Settings}"
                        MaxWidth="{Binding ElementName=PageRoot, Path=ActualWidth, Converter={StaticResource ResponsivePageContentMaxWidthConverter}}"
                        Margin="{Binding ElementName=PageRoot, Path=ActualWidth, Converter={StaticResource ResponsivePageMarginConverter}}">

                <!-- ============================================ -->
                <!--  ENCABEZADO + BANNER (preservado)           -->
                <!-- ============================================ -->
                <ui:TextBlock Text="{DynamicResource MediaFlyoutTitle}"
                              FontTypography="Title"
                              Margin="0,0,0,8"/>

                <!-- BANNER: imagen + descripción (NO BORRAR) -->
                <WrapPanel Margin="0,0,0,24">
                    <Border CornerRadius="10"
                            ClipToBounds="True"
                            Width="164"
                            Height="98"
                            Margin="0,0,12,12">
                        <Border.Background>
                            <ImageBrush ImageSource="/Resources/FluentFlyoutDemo3.1.png"
                                        Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>
                    <TextBlock Text="{DynamicResource MediaFlyoutDescription}"
                               FontSize="14"
                               FontWeight="Regular"
                               Opacity="0.75"
                               Margin="0"
                               MaxWidth="{Binding ElementName=PageRoot, Path=ActualWidth, Converter={StaticResource ResponsiveBannerTextWidthConverter}}"
                               TextWrapping="WrapWithOverflow"/>
                </WrapPanel>

                <!-- ============================================ -->
                <!--  SECCIÓN: CONTROLES PRINCIPALES              -->
                <!-- ============================================ -->
                <ui:CardControl Icon="{ui:SymbolIcon VideoPlayPause24}"
                                Margin="0,0,0,24">
                    <ui:CardControl.Header>
                        <StackPanel>
                            <TextBlock Text="{DynamicResource TextBlockText1}"
                                       FontSize="14"
                                       FontWeight="Regular"/>
                            <TextBlock Text="{DynamicResource TextBlockText3}"
                                       FontSize="12"
                                       Opacity="0.5"/>
                        </StackPanel>
                    </ui:CardControl.Header>
                    <controls:ToggleSwitch x:Name="MediaFlyoutEnabledSwitch"
                                           IsChecked="{Binding MediaFlyoutEnabled, Mode=TwoWay}"/>
                </ui:CardControl>

                <StackPanel Visibility="{Binding MediaFlyoutEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">

                    <!-- ============================================ -->
                    <!--  SECCIÓN: MEDIOS EXTERNOS                    -->
                    <!-- ============================================ -->
                    <TextBlock Text="{DynamicResource ExternalMediaSectionTitle}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"
                               Visibility="{Binding IsExternalMediaControlMode, Converter={StaticResource BoolToVisibleCollapsedConverter}}"/>

                    <StackPanel Margin="0,0,0,24">
                        <ui:CardControl Icon="{ui:SymbolIcon Pause24}"
                                        Margin="0,0,0,4"
                                        Visibility="{Binding IsExternalMediaControlMode, Converter={StaticResource BoolToVisibleCollapsedConverter}}">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource PauseOtherMediaTitle}"
                                               FontSize="14"
                                               FontWeight="Regular"/>
                                    <TextBlock Text="{DynamicResource PauseOtherMediaDescription}"
                                               FontSize="12"
                                               Opacity="0.5"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <controls:ToggleSwitch x:Name="PauseOtherSessionsEnabledSwitch"
                                                   IsChecked="{Binding PauseOtherSessionsEnabled, Mode=TwoWay}"/>
                        </ui:CardControl>

                        <ui:CardControl Icon="{ui:SymbolIcon SpeakerOff24}"
                                        Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource MediaFlyoutExcludeVolumeTitle}"
                                               FontSize="14"
                                               FontWeight="Regular"/>
                                    <TextBlock Text="{DynamicResource MediaFlyoutExcludeVolumeDescription}"
                                               FontSize="12"
                                               Opacity="0.5"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <controls:ToggleSwitch x:Name="MediaFlyoutVolumeKeysExcludedSwitch"
                                                   IsChecked="{Binding MediaFlyoutVolumeKeysExcluded, Mode=TwoWay}"/>
                        </ui:CardControl>
                    </StackPanel>

                    <!-- ============================================ -->
                    <!--  SECCIÓN: APARIENCIA Y COMPORTAMIENTO       -->
                    <!-- ============================================ -->
                    <TextBlock Text="{DynamicResource AppearanceBehaviorSectionTitle}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <StackPanel Margin="0,0,0,24">
                        <!-- Desenfoque de Fondo (Presets) -->
                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="{DynamicResource MediaFlyout_BackgroundStyleTitle}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{DynamicResource MediaFlyout_BackgroundStyleDescription}"
                                       FontSize="12"
                                       Opacity="0.6"
                                       Margin="0,0,0,12"
                                       TextWrapping="Wrap"
                                       MaxWidth="{Binding ElementName=PageRoot, Path=ActualWidth, Converter={StaticResource ResponsiveBannerTextWidthConverter}}"/>

                            <ListBox SelectedIndex="{Binding MediaFlyoutBackgroundBlur, Mode=TwoWay}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Padding="0"
                                     Margin="0"
                                     HorizontalAlignment="Stretch"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="{Binding ElementName=PageRoot, Path=ActualWidth, Converter={StaticResource ResponsiveColumnsConverter}}"/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>

                                <!-- Item 0: Ninguno -->
                                <ListBoxItem Style="{StaticResource BackdropStyleCardItem}">
                                    <Grid Height="185">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Title -->
                                        <TextBlock Grid.Row="0"
                                                   Text="{DynamicResource BackgroundBlurOption1}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Margin="0,0,0,4"/>
                                        <!-- Preview -->
                                        <Border Grid.Row="1"
                                                CornerRadius="6"
                                                Margin="0,6"
                                                ClipToBounds="True"
                                                Background="#1A1A1E">
                                            <Grid>
                                                <!-- Simulated player window -->
                                                <Border Width="56"
                                                        Height="56"
                                                        CornerRadius="6"
                                                        Background="#2D2D32"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                    <ui:SymbolIcon Symbol="Dismiss24"
                                                                   FontSize="24"
                                                                   Foreground="#40FFFFFF"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <!-- Description -->
                                        <TextBlock Grid.Row="2"
                                                   Text="{DynamicResource MediaFlyout_BackgroundBlurOption1Desc}"
                                                   FontSize="11"
                                                   Opacity="0.6"
                                                   TextWrapping="Wrap"
                                                   Height="36"/>
                                    </Grid>
                                </ListBoxItem>

                                <!-- Item 1: Resplandor de Portada -->
                                <ListBoxItem Style="{StaticResource BackdropStyleCardItem}">
                                    <Grid Height="185">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Title -->
                                        <TextBlock Grid.Row="0"
                                                   Text="{DynamicResource BackgroundBlurOption2}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Margin="0,0,0,4"/>
                                        <!-- Preview -->
                                        <Border Grid.Row="1"
                                                CornerRadius="6"
                                                Margin="0,6"
                                                ClipToBounds="True"
                                                Background="#1A1A1E">
                                            <Grid>
                                                <!-- Radial Glow -->
                                                <Ellipse Width="100"
                                                         Height="100"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center">
                                                    <Ellipse.Fill>
                                                        <RadialGradientBrush Center="0.5,0.5"
                                                                             RadiusX="0.5"
                                                                             RadiusY="0.5">
                                                            <GradientStop Color="#900078D7"
                                                                          Offset="0"/>
                                                            <GradientStop Color="#000078D7"
                                                                          Offset="1"/>
                                                        </RadialGradientBrush>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <!-- Simulated Album Art -->
                                                <Border Width="40"
                                                        Height="40"
                                                        CornerRadius="4"
                                                        Background="#FF0078D7"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                    <ui:SymbolIcon Symbol="MusicNote124"
                                                                   FontSize="16"
                                                                   Foreground="White"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <!-- Description -->
                                        <TextBlock Grid.Row="2"
                                                   Text="{DynamicResource MediaFlyout_BackgroundBlurOption2Desc}"
                                                   FontSize="11"
                                                   Opacity="0.6"
                                                   TextWrapping="Wrap"
                                                   Height="36"/>
                                    </Grid>
                                </ListBoxItem>

                                <!-- Item 2: Resplandor Ascendente -->
                                <ListBoxItem Style="{StaticResource BackdropStyleCardItem}">
                                    <Grid Height="185">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Title -->
                                        <TextBlock Grid.Row="0"
                                                   Text="{DynamicResource BackgroundBlurOption3}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Margin="0,0,0,4"/>
                                        <!-- Preview -->
                                        <Border Grid.Row="1"
                                                CornerRadius="6"
                                                Margin="0,6"
                                                ClipToBounds="True"
                                                Background="#1A1A1E">
                                            <Grid>
                                                <!-- Rising Glow -->
                                                <Border VerticalAlignment="Bottom"
                                                        Height="50">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0.5,1"
                                                                             EndPoint="0.5,0">
                                                            <GradientStop Color="#908E24AA"
                                                                          Offset="0"/>
                                                            <GradientStop Color="#008E24AA"
                                                                          Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                <!-- Simulated Album Art -->
                                                <Border Width="40"
                                                        Height="40"
                                                        CornerRadius="4"
                                                        Background="#FF8E24AA"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                    <ui:SymbolIcon Symbol="MusicNote124"
                                                                   FontSize="16"
                                                                   Foreground="White"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <!-- Description -->
                                        <TextBlock Grid.Row="2"
                                                   Text="{DynamicResource MediaFlyout_BackgroundBlurOption3Desc}"
                                                   FontSize="11"
                                                   Opacity="0.6"
                                                   TextWrapping="Wrap"
                                                   Height="36"/>
                                    </Grid>
                                </ListBoxItem>

                                <!-- Item 3: Desenfoque Suave -->
                                <ListBoxItem Style="{StaticResource BackdropStyleCardItem}">
                                    <Grid Height="185">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <!-- Title -->
                                        <TextBlock Grid.Row="0"
                                                   Text="{DynamicResource BackgroundBlurOption4}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Margin="0,0,0,4"/>
                                        <!-- Preview -->
                                        <Border Grid.Row="1"
                                                CornerRadius="6"
                                                Margin="0,6"
                                                ClipToBounds="True"
                                                Background="#1A1A1E">
                                            <Grid>
                                                <!-- Blurred backdrop simulator -->
                                                <Grid.Background>
                                                    <LinearGradientBrush StartPoint="0,0"
                                                                         EndPoint="1,1">
                                                        <GradientStop Color="#FF0B1E28"
                                                                      Offset="0"/>
                                                        <GradientStop Color="#FF24122C"
                                                                      Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Grid.Background>
                                                <Ellipse Width="150"
                                                         Height="150"
                                                         Margin="-50,-50,0,0"
                                                         HorizontalAlignment="Left"
                                                         VerticalAlignment="Top">
                                                    <Ellipse.Fill>
                                                        <RadialGradientBrush Center="0.5,0.5"
                                                                             RadiusX="0.5"
                                                                             RadiusY="0.5">
                                                            <GradientStop Color="#4000D2C4"
                                                                          Offset="0"/>
                                                            <GradientStop Color="#0000D2C4"
                                                                          Offset="1"/>
                                                        </RadialGradientBrush>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <Ellipse Width="150"
                                                         Height="150"
                                                         Margin="0,0,-50,-50"
                                                         HorizontalAlignment="Right"
                                                         VerticalAlignment="Bottom">
                                                    <Ellipse.Fill>
                                                        <RadialGradientBrush Center="0.5,0.5"
                                                                             RadiusX="0.5"
                                                                             RadiusY="0.5">
                                                            <GradientStop Color="#40E040FB"
                                                                          Offset="0"/>
                                                            <GradientStop Color="#00E040FB"
                                                                          Offset="1"/>
                                                        </RadialGradientBrush>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <!-- Simulated Album Art -->
                                                <Border Width="40"
                                                        Height="40"
                                                        CornerRadius="4"
                                                        Background="#FF00D2C4"
                                                        VerticalAlignment="Center"
                                                        HorizontalAlignment="Center">
                                                    <ui:SymbolIcon Symbol="MusicNote124"
                                                                   FontSize="16"
                                                                   Foreground="White"
                                                                   VerticalAlignment="Center"
                                                                   HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <!-- Description -->
                                        <TextBlock Grid.Row="2"
                                                   Text="{DynamicResource MediaFlyout_BackgroundBlurOption4Desc}"
                                                   FontSize="11"
                                                   Opacity="0.6"
                                                   TextWrapping="Wrap"
                                                   Height="36"/>
                                    </Grid>
                                </ListBoxItem>
                            </ListBox>
                        </StackPanel>

                        <StackPanel Margin="0,0,0,16">
                            <TextBlock Text="{DynamicResource MediaFlyout_AcrylicWindowTitle}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,4"/>
                            <TextBlock Text="{DynamicResource MediaFlyout_AcrylicWindowDescription}"
                                       FontSize="12"
                                       Opacity="0.6"
                                       Margin="0,0,0,12"
                                       TextWrapping="Wrap"
                                       MaxWidth="{Binding ElementName=PageRoot, Path=ActualWidth, Converter={StaticResource ResponsiveBannerTextWidthConverter}}"/>

                            <Border Margin="0,0,0,12"
                                    Padding="16"
                                    CornerRadius="12"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    Background="{DynamicResource ControlFillColorSecondaryBrush}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="150"
                                            Height="96"
                                            CornerRadius="10"
                                            HorizontalAlignment="Left"
                                            BorderBrush="#26FFFFFF"
                                            BorderThickness="1">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0"
                                                                 EndPoint="1,1">
                                                <GradientStop Color="#AA1C1F28"
                                                              Offset="0"/>
                                                <GradientStop Color="#CC101217"
                                                              Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                        <Grid>
                                            <Border Margin="14"
                                                    CornerRadius="8"
                                                    Background="#66FFFFFF"
                                                    BorderBrush="#22FFFFFF"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <Rectangle Margin="12,12,12,46"
                                                               RadiusX="5"
                                                               RadiusY="5"
                                                               Fill="#40FFFFFF"/>
                                                    <Rectangle Margin="12,58,42,18"
                                                               RadiusX="4"
                                                               RadiusY="4"
                                                               Fill="#33FFFFFF"/>
                                                    <Rectangle Margin="98,58,12,18"
                                                               RadiusX="4"
                                                               RadiusY="4"
                                                               Fill="#55FFFFFF"/>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                Margin="16,0,0,0"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{DynamicResource MediaFlyout_AcrylicPerk}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="{DynamicResource MediaFlyout_AcrylicPerkDescription}"
                                                   FontSize="12"
                                                   Opacity="0.6"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="{Binding ElementName=PageRoot, Path=ActualWidth, Converter={StaticResource ResponsiveBannerTextWidthConverter}}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <ui:CardControl Icon="{ui:SymbolIcon Blur24}"
                                            Margin="0,0,0,4">
                                <ui:CardControl.Header>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource AcrylicWindowTitle}"
                                                   FontSize="14"
                                                   FontWeight="Regular"/>
                                        <TextBlock Text="{DynamicResource AcrylicWindowDescription}"
                                                   FontSize="12"
                                                   Opacity="0.5"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="{Binding ElementName=PageRoot, Path=ActualWidth, Converter={StaticResource ResponsiveBannerTextWidthConverter}}"/>
                                    </StackPanel>
                                </ui:CardControl.Header>
                                <controls:ToggleSwitch x:Name="AcrylicWindowSwitch"
                                                       IsChecked="{Binding MediaFlyoutAcrylicWindowEnabled, Mode=TwoWay}"
                                                       IsEnabled="{x:Static classes:WindowBlurHelper.IsAcrylicSupported}">
                                    <controls:ToggleSwitch.Style>
                                        <Style TargetType="controls:ToggleSwitch"
                                               BasedOn="{StaticResource {x:Type controls:ToggleSwitch}}">
                                            <Style.Triggers>
                                                <Trigger Property="IsEnabled"
                                                         Value="False">
                                                    <Setter Property="ToolTip"
                                                            Value="Acrylic no está disponible en esta versión/configuración de Windows; se usará Mica."/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </controls:ToggleSwitch.Style>
                                </controls:ToggleSwitch>
                            </ui:CardControl>

                            <ui:CardControl Icon="{ui:SymbolIcon PaintBucket24}"
                                            Margin="0,0,0,4">
                                <ui:CardControl.Header>
                                    <StackPanel>
                                        <TextBlock Text="{DynamicResource AcrylicBlurOpacityTitle}"
                                                   FontSize="14"
                                                   FontWeight="Regular"/>
                                        <TextBlock Text="{DynamicResource AcrylicBlurOpacityDescription}"
                                                   FontSize="12"
                                                   Opacity="0.5"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="{Binding ElementName=PageRoot, Path=ActualWidth, Converter={StaticResource ResponsiveBannerTextWidthConverter}}"/>
                                    </StackPanel>
                                </ui:CardControl.Header>
                                <StackPanel Orientation="Horizontal"
                                            IsEnabled="{Binding ElementName=AcrylicWindowSwitch, Path=IsChecked}"
                                            Opacity="{Binding ElementName=AcrylicWindowSwitch, Path=IsChecked, Converter={StaticResource BoolToFullHalfOpacityConverter}}">
                                    <Slider Minimum="0"
                                            Maximum="255"
                                            Value="{Binding AcrylicBlurOpacity, Mode=TwoWay}"
                                            IsEnabled="{Binding IsPremiumUnlocked}"
                                            TickFrequency="5"
                                            IsSnapToTickEnabled="True"
                                            Width="{Binding ElementName=PageRoot, Path=ActualWidth, Converter={StaticResource ResponsiveInlineControlWidthConverter}, ConverterParameter=wide}"/>
                                    <ui:TextBlock Text="{Binding AcrylicBlurOpacity}"
                                                  Width="36"
                                                  TextAlignment="Center"
                                                  Margin="12,0,0,0"/>
                                </StackPanel>
                            </ui:CardControl>
                        </StackPanel>

                        <ui:CardControl Icon="{ui:SymbolIcon ArrowAutofitWidth24}"
                                        Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource CompactLayoutTitle}"
                                               FontSize="14"
                                               FontWeight="Regular"/>
                                    <TextBlock Text="{DynamicResource CompactLayoutDescription}"
                                               FontSize="12"
                                               Opacity="0.5"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <controls:ToggleSwitch x:Name="LayoutSwitch"
                                                   IsChecked="{Binding CompactLayout, Mode=TwoWay}"/>
                        </ui:CardControl>

                        <ui:CardControl Icon="{ui:SymbolIcon ArrowMove24}"
                                        Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <TextBlock Text="{DynamicResource FlyoutPositionTitle}"
                                           FontSize="14"
                                           FontWeight="Regular"/>
                            </ui:CardControl.Header>
                            <ComboBox x:Name="PositionComboBox"
                                      SelectedIndex="{Binding Position, Mode=TwoWay}"
                                      Width="{Binding ElementName=PageRoot, Path=ActualWidth, Converter={StaticResource ResponsiveInlineControlWidthConverter}, ConverterParameter=wide}">
                                <ComboBoxItem Content="{DynamicResource PositionBottomLeft}"/>
                                <ComboBoxItem Content="{DynamicResource PositionBottomCenter}"/>
                                <ComboBoxItem Content="{DynamicResource PositionBottomRight}"/>
                                <ComboBoxItem Content="{DynamicResource PositionTopLeft}"/>
                                <ComboBoxItem Content="{DynamicResource PositionTopCenter}"/>
                                <ComboBoxItem Content="{DynamicResource PositionTopRight}"/>
                            </ComboBox>
                        </ui:CardControl>

                        <ui:CardControl Icon="{ui:SymbolIcon Timer24}"
                                        Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource FlyoutStayDurationTitle}"
                                               FontSize="14"
                                               FontWeight="Regular"/>
                                    <TextBlock Text="{DynamicResource FlyoutStayDurationDescription}"
                                               FontSize="12"
                                               Opacity="0.5"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <StackPanel Orientation="Horizontal">
                                <ui:TextBox x:Name="DurationTextBox"
                                            Width="60"
                                            ClearButtonEnabled="False"
                                            Text="{Binding DurationText, Mode=TwoWay}"
                                            IsEnabled="{Binding IsDurationEditable, Mode=OneWay}"/>
                                <TextBlock Text="{DynamicResource MillisecondsUnit}"
                                           FontSize="14"
                                           FontWeight="Regular"
                                           Margin="10,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </ui:CardControl>

                        <ui:CardControl Icon="{ui:SymbolIcon TimerOff24}"
                                        Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource MediaFlyoutAlwaysDisplay}"
                                               FontSize="14"
                                               FontWeight="Regular"/>
                                    <TextBlock Text="{DynamicResource MediaFlyoutAlwaysDisplayDescription}"
                                               FontSize="12"
                                               Opacity="0.7"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <controls:ToggleSwitch IsChecked="{Binding MediaFlyoutAlwaysDisplay, Mode=TwoWay}"/>
                        </ui:CardControl>
                    </StackPanel>

                    <!-- ============================================ -->
                    <!--  SECCIÓN: FUNCIONALIDADES Y DISEÑO          -->
                    <!-- ============================================ -->
                    <TextBlock Text="{DynamicResource FeaturesLayoutSectionTitle}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>

                    <StackPanel Margin="0,0,0,24">
                        <ui:CardControl Icon="{ui:SymbolIcon AlignLeft24}"
                                        Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource CenterTitleArtistTitle}"
                                               FontSize="14"
                                               FontWeight="Regular"/>
                                    <TextBlock Text="{DynamicResource CenterTitleArtistDescription}"
                                               FontSize="12"
                                               Opacity="0.5"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <controls:ToggleSwitch x:Name="CenterTitleArtistSwitch"
                                                   IsChecked="{Binding CenterTitleArtist, Mode=TwoWay}"/>
                        </ui:CardControl>

                        <ui:CardControl Icon="{ui:SymbolIcon Subtitles24}"
                                        Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <TextBlock Text="{DynamicResource ShowMediaPlayerNameTitle}"
                                           FontSize="14"
                                           FontWeight="Regular"/>
                            </ui:CardControl.Header>
                            <controls:ToggleSwitch x:Name="PlayerInfoSwitch"
                                                   IsChecked="{Binding PlayerInfoEnabled, Mode=TwoWay}"/>
                        </ui:CardControl>

                        <ui:CardControl Icon="{ui:SymbolIcon ArrowRepeatAll24}"
                                        Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource RepeatButtonTitle}"
                                               FontSize="14"
                                               FontWeight="Regular"/>
                                    <TextBlock Text="{DynamicResource RepeatButtonDescription}"
                                               FontSize="12"
                                               Opacity="0.5"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <controls:ToggleSwitch x:Name="RepeatSwitch"
                                                   IsChecked="{Binding RepeatEnabled, Mode=TwoWay}"/>
                        </ui:CardControl>

                        <ui:CardControl Icon="{ui:SymbolIcon ArrowShuffle24}"
                                        Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource ShuffleButtonTitle}"
                                               FontSize="14"
                                               FontWeight="Regular"/>
                                    <TextBlock Text="{DynamicResource ShuffleButtonDescription}"
                                               FontSize="12"
                                               Opacity="0.5"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <controls:ToggleSwitch x:Name="ShuffleSwitch"
                                                   IsChecked="{Binding ShuffleEnabled, Mode=TwoWay}"/>
                        </ui:CardControl>

                        <ui:CardControl Icon="{ui:SymbolIcon SlideArrowRight24}"
                                        Margin="0,0,0,4">
                            <ui:CardControl.Header>
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource ShowSeekbarTitle}"
                                               FontSize="14"
                                               FontWeight="Regular"/>
                                    <TextBlock Text="{DynamicResource ShowSeekbarDescription}"
                                               FontSize="12"
                                               Opacity="0.5"/>
                                </StackPanel>
                            </ui:CardControl.Header>
                            <controls:ToggleSwitch x:Name="SeekbarSwitch"
                                                   IsChecked="{Binding SeekbarEnabled, Mode=TwoWay}"/>
                        </ui:CardControl>
                    </StackPanel>

                    <!-- AVISO ADICIONAL -->
                    <ui:InfoBar Title="{DynamicResource UnsupportedControlsWarning}"
                                IsOpen="True"
                                Severity="Warning"
                                IsClosable="False"
                                Margin="0,0,0,24"/>

                    <!-- Espacio final para scroll -->
                    <Border Height="40"/>

                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
