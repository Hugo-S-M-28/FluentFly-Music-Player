<UserControl
    x:Class="FluentFlyout.Controls.TaskbarWidgetControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewModels="clr-namespace:FluentFlyoutWPF.ViewModels"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance viewModels:SettingsShellViewModel}"
    Height="40"
    Width="100"
    TextOptions.TextRenderingMode="ClearType"
    TextOptions.TextFormattingMode="Ideal"
    FontFamily="Segoe UI Variable, Microsoft YaHei, Microsoft JhengHei, MS Gothic"
    FlowDirection="{Binding Settings.FlowDirection}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/FluentFlyout;component/Resources/SharedThemeResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>
    <Border Name="MainBorder"
            DataContext="{Binding Settings}"
            CornerRadius="6"
            MouseEnter="Grid_MouseEnter"
            MouseLeave="Grid_MouseLeave"
            MouseLeftButtonUp="Grid_MouseLeftButtonUp"
            ClipToBounds="True">
        <Grid x:Name="RootGrid">
            <Image x:Name="BackgroundImage"
                   Stretch="UniformToFill"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   RenderTransformOrigin="0.5,0.5"
                   Opacity="0.4">
                <Image.Effect>
                    <BlurEffect Radius="80"/>
                </Image.Effect>
            </Image>
            <!-- unused next image for crossfade effect
            <Image x:Name="BackgroundImageNext" Stretch="UniformToFill" HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5" Opacity="0">
                <Image.Effect>
                    <BlurEffect Radius="80" />
                </Image.Effect>
            </Image> -->

            <Border Name="TopBorder"
                    BorderThickness="0,1.25,0,0"
                    CornerRadius="5"
                    Margin="0,0,0,1.25">
                <Grid Name="MainGrid"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      RenderTransformOrigin="0,0.5">
                    <Grid.RenderTransform>
                        <ScaleTransform ScaleX="0.9"
                                        ScaleY="0.9"/>
                    </Grid.RenderTransform>
                    <StackPanel Name="MainStackPanel"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Width="Auto"
                                Margin="4,0,-100,0">
                        <Border Name="SongImageBorder"
                                CornerRadius="5"
                                Margin="0,0,0,-2"
                                ClipToBounds="True"
                                Width="36"
                                Height="36"
                                Panel.ZIndex="2">
                            <Grid>
                                <ui:SymbolIcon Name="SongImagePlaceholder"
                                               Symbol="MusicNote220"
                                               FontSize="24"
                                               Filled="True"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <!--<Image x:Name="VisualizerContainer" Width="Auto" Height="Auto" Margin="4" />-->
                            </Grid>
                            <Border.Background>
                                <ImageBrush x:Name="SongImage"
                                            Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>

                        <StackPanel Name="SongInfoStackPanel"
                                    Orientation="Vertical"
                                    VerticalAlignment="Center"
                                    Width="Auto"
                                    Margin="8,0,0,0"
                                    ToolTipService.InitialShowDelay="800"
                                    ToolTipService.Placement="RelativePoint"
                                    ToolTipService.VerticalOffset="-16">
                            <TextBlock Name="SongTitle"
                                       Text=""
                                       FontWeight="Normal"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Name="SongArtist"
                                       Text=""
                                       FontWeight="Normal"
                                       Opacity="0.5"
                                       Margin="0,-1.5,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <StackPanel Name="ControlsStackPanel"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Width="Auto"
                                    Margin="8,0,0,0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TaskbarWidgetControlsEnabled}"
                                                     Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <ui:Button Name="PreviousButton"
                                       Appearance="Transparent"
                                       Height="32"
                                       Width="32"
                                       Padding="0"
                                       BorderThickness="0"
                                       Margin="0,0,0,-1"
                                       Click="Previous_Click">
                                <ui:SymbolIcon Name="PreviousIcon"
                                               Symbol="Previous20"
                                               Filled="True"/>
                            </ui:Button>
                            <ui:Button Name="PlayPauseButton"
                                       Appearance="Transparent"
                                       Height="32"
                                       Width="32"
                                       Padding="0"
                                       BorderThickness="0"
                                       Margin="0,0,0,-1"
                                       Click="PlayPause_Click">
                                <ui:SymbolIcon Name="PlayPauseIcon"
                                               Symbol="Pause16"
                                               Filled="True"/>
                            </ui:Button>
                            <ui:Button Name="NextButton"
                                       Appearance="Transparent"
                                       Height="32"
                                       Width="32"
                                       Padding="0"
                                       BorderThickness="0"
                                       Margin="0,0,0,-1"
                                       Click="Next_Click">
                                <ui:SymbolIcon Name="NextIcon"
                                               Symbol="Next20"
                                               Filled="True"/>
                            </ui:Button>
                        </StackPanel>

                    </StackPanel>
                </Grid>
            </Border>

            <Rectangle Name="ProgressLine"
                       Height="2"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Left"
                       Width="0"
                       Fill="{DynamicResource TextFillColorSecondaryBrush}"
                       Visibility="Collapsed"/>
        </Grid>
    </Border>
</UserControl>
