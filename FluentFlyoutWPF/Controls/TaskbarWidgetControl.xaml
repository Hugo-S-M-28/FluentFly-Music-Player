<UserControl
    x:Class="FluentFlyout.Controls.TaskbarWidgetControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewModels="clr-namespace:FluentFlyoutWPF.ViewModels"
    xmlns:behaviors="clr-namespace:FluentFlyoutWPF.Classes.Behaviors"
    x:Name="RootControl"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance viewModels:TaskbarWidgetViewModel}"
    Height="40"
    Width="100"
    TextOptions.TextRenderingMode="ClearType"
    TextOptions.TextFormattingMode="Ideal"
    FontFamily="Segoe UI Variable, Microsoft YaHei, Microsoft JhengHei, MS Gothic"
    FlowDirection="{Binding Settings.FlowDirection}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/FluentFlyout;component/Resources/SharedThemeResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid RenderTransformOrigin="0,0.5">
        <Grid.RenderTransform>
            <ScaleTransform ScaleX="0.9"
                            ScaleY="0.9"/>
        </Grid.RenderTransform>
        <Image x:Name="BackgroundImage"
               Stretch="Fill"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Stretch"
               RenderTransformOrigin="0.5,0.5"
               Opacity="0.4"
               behaviors:MediaBackdropBehavior.Source="{Binding BackdropImage}"
               behaviors:MediaBackdropBehavior.Preset="{Binding Settings.MediaFlyoutBackgroundBlur}"
               behaviors:MediaBackdropBehavior.Surface="Taskbar"
               behaviors:MediaBackdropBehavior.IsEnabled="{Binding Settings.TaskbarWidgetBackgroundBlur}"
               Visibility="{Binding Settings.TaskbarWidgetBackgroundBlur, Converter={StaticResource BoolToVisibleCollapsedConverter}}">
            <Image.Effect>
                <BlurEffect Radius="80"/>
            </Image.Effect>
        </Image>

        <Border Name="MainBorder"
                CornerRadius="6"
                MouseEnter="Grid_MouseEnter"
                MouseLeave="Grid_MouseLeave"
                MouseLeftButtonUp="Grid_MouseLeftButtonUp"
                ClipToBounds="True">
            <Grid x:Name="RootGrid">
                <Border Name="TopBorder"
                        BorderThickness="0,1.25,0,0"
                        CornerRadius="5"
                        Margin="0,0,0,1.25">
                    <Grid Name="MainGrid"
                          Margin="4,0,4,0"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition x:Name="LeftControlsColumn"
                                              Width="0"/>
                            <ColumnDefinition x:Name="LeftControlsGapColumn"
                                              Width="0"/>
                            <ColumnDefinition x:Name="CoverColumn"
                                              Width="36"/>
                            <ColumnDefinition x:Name="CoverTextGapColumn"
                                              Width="8"/>
                            <ColumnDefinition x:Name="TextColumn"
                                              Width="*"
                                              MinWidth="0"/>
                            <ColumnDefinition x:Name="TextControlsGapColumn"
                                              Width="8"/>
                            <ColumnDefinition x:Name="RightControlsColumn"
                                              Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Name="ControlsStackPanel"
                                    Grid.Column="6"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Left"
                                    Width="Auto"
                                    Margin="0">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility"
                                            Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Settings.TaskbarWidgetControlsEnabled}"
                                                     Value="True">
                                            <Setter Property="Visibility"
                                                    Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <ui:Button Name="PreviousButton"
                                       Appearance="Transparent"
                                       Height="32"
                                       Width="32"
                                       Padding="0"
                                       BorderThickness="0"
                                       IsHitTestVisible="{Binding CanPrevious}"
                                       Opacity="{Binding PreviousOpacity}"
                                       Command="{Binding PreviousCommand}">
                                <ui:SymbolIcon Name="PreviousIcon"
                                               Symbol="Previous20"
                                               Foreground="{Binding ControlsForeground}"
                                               Filled="True"/>
                            </ui:Button>
                            <ui:Button Name="PlayPauseButton"
                                       Appearance="Transparent"
                                       Height="32"
                                       Width="32"
                                       Padding="0"
                                       BorderThickness="0"
                                       IsHitTestVisible="{Binding CanPlayPause}"
                                       Opacity="{Binding PlayPauseOpacity}"
                                       Command="{Binding PlayPauseCommand}">
                                <ui:SymbolIcon Name="PlayPauseIcon"
                                               Symbol="{Binding PlayPauseSymbol}"
                                               Foreground="{Binding ControlsForeground}"
                                               Filled="True"/>
                            </ui:Button>
                            <ui:Button Name="NextButton"
                                       Appearance="Transparent"
                                       Height="32"
                                       Width="32"
                                       Padding="0"
                                       BorderThickness="0"
                                       IsHitTestVisible="{Binding CanNext}"
                                       Opacity="{Binding NextOpacity}"
                                       Command="{Binding NextCommand}">
                                <ui:SymbolIcon Name="NextIcon"
                                               Symbol="Next20"
                                               Foreground="{Binding ControlsForeground}"
                                               Filled="True"/>
                            </ui:Button>
                        </StackPanel>

                        <Border Name="SongImageBorder"
                                Grid.Column="2"
                                CornerRadius="5"
                                VerticalAlignment="Center"
                                ClipToBounds="True"
                                Width="36"
                                Height="36"
                                Panel.ZIndex="2">
                            <Grid>
                                <ui:SymbolIcon Name="SongImagePlaceholder"
                                               Symbol="{Binding PlaceholderSymbol}"
                                               FontSize="24"
                                               Filled="True"
                                               Foreground="{Binding ControlsForeground}"
                                               Visibility="{Binding PlaceholderVisibility}"/>
                                <!--<Image x:Name="VisualizerContainer" Width="Auto" Height="Auto" Margin="4" />-->
                            </Grid>
                            <Border.Background>
                                <ImageBrush x:Name="SongImage"
                                            ImageSource="{Binding CoverImage}"
                                            Opacity="{Binding CoverOpacity}"
                                            Stretch="UniformToFill"/>
                            </Border.Background>
                        </Border>

                        <StackPanel Name="SongInfoStackPanel"
                                    Grid.Column="4"
                                    Orientation="Vertical"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Stretch"
                                    MinWidth="0"
                                    Width="Auto"
                                    Margin="0"
                                    Visibility="{Binding SongInfoVisibility}"
                                    ToolTip="{Binding TooltipText}"
                                    ToolTipService.InitialShowDelay="800"
                                    ToolTipService.Placement="RelativePoint"
                                    ToolTipService.VerticalOffset="-16">
                            <TextBlock Name="SongTitle"
                                       Text="{Binding Title}"
                                       FontWeight="Normal"
                                       Foreground="{Binding TitleForeground}"
                                       HorizontalAlignment="Stretch"
                                       MinWidth="0"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Name="SongArtist"
                                       Text="{Binding Artist}"
                                       FontWeight="Normal"
                                       Foreground="{Binding SecondaryForeground}"
                                       Opacity="0.78"
                                       Visibility="{Binding ArtistVisibility}"
                                       HorizontalAlignment="Stretch"
                                       MinWidth="0"
                                       TextWrapping="NoWrap"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <Rectangle Name="ProgressLine"
                           Height="2"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Left"
                           Width="0"
                           Fill="{Binding ControlsForeground}"
                           Visibility="{Binding ProgressVisibility}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
