<UserControl
    x:Class="FluentFlyoutWPF.Controls.PlaylistControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:models="clr-namespace:FluentFlyoutWPF.Models"
    xmlns:classes="clr-namespace:FluentFlyoutWPF.Classes"
    xmlns:behaviors="clr-namespace:FluentFlyoutWPF.Classes.Behaviors"
    xmlns:utils="clr-namespace:FluentFlyoutWPF.Classes.Utils"
    mc:Ignorable="d"
    d:DesignHeight="450"
    d:DesignWidth="340"
    x:Name="RootControl">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/FluentFlyout;component/Resources/Converters.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <classes:PathToImageConverter x:Key="PathToImageConverter"/>
            <local:IsCurrentTrackConverter x:Key="IsCurrentTrackConverter"
                                           xmlns:local="clr-namespace:FluentFlyoutWPF.Controls"/>
            <Style x:Key="DropIndicatorStyle"
                   TargetType="Border">
                <Setter Property="Height"
                        Value="2"/>
                <Setter Property="Background"
                        Value="{DynamicResource AccentFillColorDefaultBrush}"/>
                <Setter Property="CornerRadius"
                        Value="1"/>
                <Setter Property="Margin"
                        Value="12,0"/>
                <Setter Property="Visibility"
                        Value="Collapsed"/>
            </Style>

            <BooleanToVisibilityConverter x:Key="BoolToVisibleCollapsedConverter"/>

            <ContextMenu x:Key="PlaylistContextMenu">
                <MenuItem Header="{DynamicResource Playlist_PlayNext}"
                          Command="{Binding PlacementTarget.Tag.PlayNextCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                    <MenuItem.Icon>
                        <ui:SymbolIcon Symbol="Play24"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{DynamicResource Playlist_RemoveFromQueue}"
                          Command="{Binding PlacementTarget.Tag.RemoveFromQueueCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                    <MenuItem.Icon>
                        <ui:SymbolIcon Symbol="Delete24"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem Header="{DynamicResource Playlist_ViewInfo}"
                          Command="{Binding PlacementTarget.Tag.ViewInfoCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                    <MenuItem.Icon>
                        <ui:SymbolIcon Symbol="Info24"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Header="{DynamicResource Playlist_OpenLocation}"
                          Command="{Binding PlacementTarget.Tag.OpenLocationCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                          CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                    <MenuItem.Icon>
                        <ui:SymbolIcon Symbol="Folder24"/>
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </ResourceDictionary>
    </UserControl.Resources>

    <ui:Card x:Name="RootCard"
             Padding="0"
             VerticalAlignment="Stretch"
             Background="{DynamicResource ControlFillColorDefaultBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Margin="{Binding ElementName=RootControl, Path=ActualWidth, Converter={StaticResource ResponsivePageMarginConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon Symbol="Collections24"
                               FontSize="18"
                               Margin="0,0,8,0"
                               Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                               Grid.Column="0"/>
                <ui:TextBlock FontSize="15"
                              FontWeight="SemiBold"
                              Text="{DynamicResource Playlist_Title}"
                              Grid.Column="1"
                              VerticalAlignment="Center"/>
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal">
                    <ui:Button Appearance="Transparent"
                               Padding="4"
                               Margin="0,0,2,0"
                               ToolTip="{DynamicResource Playlist_LoadQueue}"
                               Command="{Binding LoadPlaylistCommand}">
                        <ui:SymbolIcon Symbol="FolderOpen24"
                                       FontSize="16"
                                       Opacity="0.8"/>
                    </ui:Button>
                    <ui:Button Appearance="Transparent"
                               Padding="4"
                               Margin="0,0,2,0"
                               ToolTip="{DynamicResource Playlist_SaveQueue}"
                               Command="{Binding SavePlaylistCommand}">
                        <ui:SymbolIcon Symbol="Save24"
                                       FontSize="16"
                                       Opacity="0.8"/>
                    </ui:Button>
                    <ui:Button Appearance="Transparent"
                               Padding="4"
                               ToolTip="{DynamicResource Playlist_ClearQueue}"
                               Command="{Binding ClearQueueCommand}">
                        <ui:SymbolIcon Symbol="Delete24"
                                       FontSize="16"
                                       Opacity="0.8"/>
                    </ui:Button>
                    <ui:Button Appearance="Transparent"
                               Padding="4"
                               Margin="2,0,0,0"
                               ToolTip="{DynamicResource Playlist_Close}"
                               Command="{Binding ElementName=RootControl, Path=CloseCommand}">
                        <ui:SymbolIcon Symbol="Dismiss24"
                                       FontSize="16"
                                       Opacity="0.8"/>
                    </ui:Button>
                </StackPanel>
            </Grid>

            <ui:TextBox x:Name="SearchBox"
                        Grid.Row="1"
                        Margin="{Binding ElementName=RootControl, Path=ActualWidth, Converter={StaticResource ResponsivePageMarginConverter}}"
                        PlaceholderText="{DynamicResource Playlist_SearchPlaceholder}"
                        Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                        Icon="Search24"
                        ClearButtonEnabled="True"/>

            <TextBlock x:Name="QueueSummaryText"
                       Grid.Row="2"
                       Margin="{Binding ElementName=RootControl, Path=ActualWidth, Converter={StaticResource ResponsivePageMarginConverter}}"
                       FontSize="12"
                       Opacity="0.6"
                       Text="{Binding QueueSummaryText}"
                       TextWrapping="Wrap"
                       Visibility="{Binding ElementName=RootControl, Path=ActualWidth, Converter={StaticResource ResponsiveCompactVisibilityConverter}}"/>

            <ListView x:Name="PlaylistListView"
                      Grid.Row="3"
                      ItemsSource="{Binding PlaylistView}"
                      SelectionMode="Extended"
                      Background="Transparent"
                      BorderThickness="0"
                      Padding="{Binding ElementName=RootControl, Path=ActualWidth, Converter={StaticResource ResponsivePageMarginConverter}}"
                      AllowDrop="True"
                      behaviors:PlaylistInteractionBehavior.IsEnabled="True"
                      behaviors:PlaylistInteractionBehavior.ViewModel="{Binding}"
                      behaviors:PlaylistInteractionBehavior.DropIndicator="{Binding ElementName=DropIndicator}"
                      ScrollViewer.VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                      ScrollViewer.CanContentScroll="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.ScrollUnit="Pixel"
                      VirtualizingPanel.VirtualizationMode="Recycling"
                      HorizontalContentAlignment="Stretch"
                      VerticalContentAlignment="Center">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Padding"
                                Value="8,5"/>
                        <Setter Property="ContextMenu"
                                Value="{StaticResource PlaylistContextMenu}"/>
                        <Setter Property="Tag"
                                Value="{Binding DataContext, ElementName=RootCard}"/>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:TrackModel}">
                        <Grid Margin="0,3"
                              Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <!-- Drag handle -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Track number -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Album art -->
                                <ColumnDefinition Width="*"/>
                                <!-- Title/Artist -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Duration -->
                            </Grid.ColumnDefinitions>

                            <!-- Drag handle -->
                            <ui:SymbolIcon x:Name="DragHandle"
                                           Symbol="ReOrderDotsVertical24"
                                           FontSize="16"
                                           Opacity="0.2"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"
                                           Cursor="SizeAll"
                                           Visibility="{Binding ElementName=RootControl, Path=ActualWidth, Converter={StaticResource ResponsiveCompactVisibilityConverter}}"/>

                            <!-- Track Number — binds to TrackModel.DisplayIndex (1-based, set by SyncQueue).
                                 Immune to VirtualizationMode=Recycling scroll bugs. -->
                            <TextBlock Grid.Column="1"
                                       FontSize="13"
                                       Opacity="0.4"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"
                                       Width="22"
                                       TextAlignment="Right"
                                       Text="{Binding DisplayIndex, StringFormat={}{0}.}"
                                       Visibility="{Binding ElementName=RootControl, Path=ActualWidth, Converter={StaticResource ResponsiveCompactVisibilityConverter}}"/>

                            <!-- Album art -->
                            <Border Grid.Column="2"
                                    CornerRadius="8"
                                    Width="40"
                                    Height="40"
                                    Margin="0,0,12,0"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}">
                                <Border CornerRadius="8"
                                        ClipToBounds="True">
                                    <Grid>
                                        <ui:SymbolIcon Symbol="MusicNote124"
                                                       Opacity="0.3"
                                                       FontSize="20"/>
                                        <Border CornerRadius="8"
                                                RenderOptions.BitmapScalingMode="HighQuality">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding AlbumArtPath, Converter={StaticResource PathToImageConverter}, ConverterParameter=80, Mode=OneWay}"
                                                            Stretch="UniformToFill"/>
                                            </Border.Background>
                                        </Border>

                                        <!-- Playing Now Indicator -->
                                        <Border Background="#80000000"
                                                CornerRadius="8">
                                            <Border.Visibility>
                                                <MultiBinding Converter="{StaticResource IsCurrentTrackConverter}">
                                                    <Binding/>
                                                    <Binding Path="CurrentTrack"
                                                             Source="{x:Static classes:MusicPlayerService.Instance}"/>
                                                </MultiBinding>
                                            </Border.Visibility>
                                            <ui:SymbolIcon Symbol="Play24"
                                                           Foreground="White"
                                                           FontSize="22"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Border>

                            <StackPanel Grid.Column="3"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}"
                                           FontSize="14.5"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Text="{Binding Artist}"
                                           FontSize="12.5"
                                           Opacity="0.6"
                                           Margin="0,2,0,0"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <TextBlock Grid.Column="4"
                                       Text="{Binding Duration, StringFormat={}{0:mm\\:ss}}"
                                       FontSize="13"
                                       Opacity="0.6"
                                       VerticalAlignment="Center"/>
                        </Grid>
                        <DataTemplate.Triggers>
                            <Trigger Property="IsMouseOver"
                                     Value="True">
                                <Setter TargetName="DragHandle"
                                        Property="Opacity"
                                        Value="0.8"/>
                            </Trigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Drop indicator line (overlaid on the ListView) -->
            <Canvas x:Name="DropIndicatorCanvas"
                    Grid.Row="3"
                    IsHitTestVisible="False">
                <Border x:Name="DropIndicator"
                        Height="2"
                        Background="{DynamicResource AccentFillColorDefaultBrush}"
                        CornerRadius="1"
                        Visibility="Collapsed"
                        Canvas.Left="12">
                    <Border.Effect>
                        <DropShadowEffect Color="{DynamicResource SystemAccentColor}"
                                          BlurRadius="6"
                                          ShadowDepth="0"
                                          Opacity="0.5"/>
                    </Border.Effect>
                </Border>
            </Canvas>

            <!-- Empty State -->
            <StackPanel Grid.Row="3"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Margin="{Binding ElementName=RootControl, Path=ActualWidth, Converter={StaticResource ResponsivePageMarginConverter}}">
                <StackPanel.Style>
                    <Style TargetType="StackPanel">
                        <Setter Property="Visibility"
                                Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Items.Count, ElementName=PlaylistListView}"
                                         Value="0">
                                <Setter Property="Visibility"
                                        Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </StackPanel.Style>
                <ui:SymbolIcon Symbol="MusicNote124"
                               FontSize="48"
                               Opacity="0.2"
                               Margin="0,0,0,16"/>
                <TextBlock Text="{DynamicResource Playlist_EmptyTitle}"
                           FontWeight="SemiBold"
                           FontSize="16"
                           TextAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock Text="{DynamicResource Playlist_EmptyDescription}"
                           TextAlignment="Center"
                           Opacity="0.6"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Undo Toast/Banner -->
            <Border x:Name="UndoBanner"
                    Grid.Row="3"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Stretch"
                    Margin="12,0,12,12"
                    Padding="12,8"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="{Binding IsUndoBannerVisible, Converter={StaticResource BoolToVisibleCollapsedConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="UndoText"
                               Text="{Binding UndoBannerText}"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Opacity="0.8"/>
                    <ui:Button Grid.Column="1"
                               Appearance="Secondary"
                               Padding="8,4"
                               Content="{DynamicResource Playlist_Undo}"
                               Icon="ArrowUndo24"
                               Command="{Binding UndoCommand}"/>
                </Grid>
            </Border>
        </Grid>
    </ui:Card>
</UserControl>
