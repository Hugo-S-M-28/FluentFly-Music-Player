<UserControl
    x:Class="FluentFlyout.Controls.TaskbarVisualizerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:viewModels="clr-namespace:FluentFlyoutWPF.ViewModels"
    xmlns:behaviors="clr-namespace:FluentFlyoutWPF.Classes.Behaviors"
    x:Name="RootControl"
    mc:Ignorable="d"
    d:DataContext="{d:DesignInstance viewModels:TaskbarVisualizerViewModel}"
    Height="40"
    Width="84"
    TextOptions.TextRenderingMode="ClearType"
    TextOptions.TextFormattingMode="Ideal"
    FontFamily="Segoe UI Variable, Microsoft YaHei, Microsoft JhengHei, MS Gothic"
    FlowDirection="{Binding Settings.FlowDirection}"
    HorizontalAlignment="Center"
    VerticalAlignment="Center">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/FluentFlyout;component/Resources/SharedThemeResources.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid Visibility="{Binding Settings.TaskbarVisualizerEnabled, Converter={StaticResource BoolToVisibleCollapsedConverter}}">
        <Grid Visibility="{Binding Settings.TaskbarVisualizerHasContent, Converter={StaticResource BoolToVisibleCollapsedConverter}}">
            <!-- Background image for unified blur preset (placed outside to prevent clipping) -->
            <Image x:Name="BackgroundBlurImage"
                   Stretch="Fill"
                   Opacity="0"
                   IsHitTestVisible="False"
                   HorizontalAlignment="Stretch"
                   VerticalAlignment="Stretch"
                   RenderTransformOrigin="0.5,0.5"
                   behaviors:MediaBackdropBehavior.Source="{Binding BackdropImage}"
                   behaviors:MediaBackdropBehavior.Preset="{Binding Settings.MediaFlyoutBackgroundBlur}"
                   behaviors:MediaBackdropBehavior.Surface="Taskbar">
                <Image.Effect>
                    <BlurEffect Radius="0"/>
                </Image.Effect>
            </Image>

            <Border Name="MainBorder"
                    CornerRadius="6"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    ClipToBounds="True"
                    MouseEnter="Grid_MouseEnter"
                    MouseLeave="Grid_MouseLeave"
                    MouseLeftButtonUp="Grid_MouseLeftButtonUp">
                <Grid>
                    <Border Name="TopBorder"
                            BorderThickness="0,1.25,0,0"
                            BorderBrush="Transparent"
                            CornerRadius="5"
                            Margin="0,0,0,1.25">
                        <Image x:Name="VisualizerContainer"
                               Margin="4,0"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
